{
  "_metadata": {
    "name": "ltx-2.3-t2v",
    "description": "LTX-Video 2.3 text-to-video with native audio. Single-stage (no upscaler chain). The bridge's `comfyui_image__generate_video` tool routes here when no init_image_* is set. To activate: replace the placeholder nodes below with an API-format export of Lightricks' reference t2v workflow (see workflows/README.md → 'LTX-Video 2.3 templates'), then tune the `targets` table to match your exported node IDs.",
    "kind": "video",
    "checkpoint_required": false,
    "defaults": {
      "width": 512,
      "height": 768,
      "length": 96,
      "fps": 24,
      "negative": ""
    },

    "//": "TARGETS TABLE — bridge param → (node id, input key)",
    "//comment-prompt":  "Positive CLIPTextEncode. Look for the one whose `inputs.clip` link traces back to LTXAVTextEncoderLoader's CLIP output AND whose `inputs.text` is the positive prompt in your export.",
    "//comment-negative": "Negative CLIPTextEncode. Same as above but text is the negative prompt.",
    "//comment-width":    "EmptyLTXVLatentVideo.width — the only node in the LTX core that emits an empty video latent.",
    "//comment-height":   "EmptyLTXVLatentVideo.height",
    "//comment-length":   "EmptyLTXVLatentVideo.length (frames, NOT seconds).",
    "//comment-fps":      "LTXVConditioning.fps — combines text + length + fps into the video conditioning. NOT SaveVideo's fps; the conditioning fps is what determines motion timing.",
    "//comment-seed":     "RandomNoise.noise_seed — the SamplerCustomAdvanced chain's noise source.",
    "//comment-steps":    "ManualSigmas — input depends on your scheduler: BasicScheduler uses `steps`, ManualSigmas uses `sigmas` (comma-separated string). Leave undeclared if your workflow uses ManualSigmas; the agent won't pass `steps` for video anyway.",
    "//comment-cfg":      "CFGGuider.cfg (or SamplerCustomAdvanced.cfg, depending on which chain your export uses).",
    "//comment-audio_enabled": "(OPTIONAL) Tie this to a workflow-level switch — e.g., a SetNode that gates the audio decode chain. Without explicit support the bridge's audio_enabled arg silently no-ops and audio is always present.",

    "targets": {
      "prompt":         { "node": "REPLACE_ME_POS_CLIP_NODE_ID",  "input": "text" },
      "negative":       { "node": "REPLACE_ME_NEG_CLIP_NODE_ID",  "input": "text" },
      "width":          { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "width" },
      "height":         { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "height" },
      "length":         { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "length" },
      "fps":            { "node": "REPLACE_ME_LTX_CONDITIONING_NODE_ID", "input": "fps" },
      "seed":           { "node": "REPLACE_ME_RANDOM_NOISE_NODE_ID", "input": "noise_seed" }
    }
  },

  "//": "Replace the block below with an API-format export of Lightricks' t2v reference workflow, then update the `targets` above with the actual node IDs. See workflows/README.md → 'LTX-Video 2.3 templates' for the full operator recipe.",

  "REPLACE_ME_POS_CLIP_NODE_ID":  { "class_type": "CLIPTextEncode",         "inputs": { "text": "placeholder positive prompt",  "clip": ["REPLACE_ME_TEXT_ENCODER_LOADER", 0] } },
  "REPLACE_ME_NEG_CLIP_NODE_ID":  { "class_type": "CLIPTextEncode",         "inputs": { "text": "",                              "clip": ["REPLACE_ME_TEXT_ENCODER_LOADER", 0] } },
  "REPLACE_ME_EMPTY_LATENT_NODE_ID":     { "class_type": "EmptyLTXVLatentVideo", "inputs": { "width": 512, "height": 768, "length": 96, "batch_size": 1 } },
  "REPLACE_ME_LTX_CONDITIONING_NODE_ID": { "class_type": "LTXVConditioning",      "inputs": { "positive": ["REPLACE_ME_POS_CLIP_NODE_ID", 0], "negative": ["REPLACE_ME_NEG_CLIP_NODE_ID", 0], "frame_rate": 24 } },
  "REPLACE_ME_RANDOM_NOISE_NODE_ID":     { "class_type": "RandomNoise",           "inputs": { "noise_seed": 0 } },
  "REPLACE_ME_TEXT_ENCODER_LOADER":      { "class_type": "LTXAVTextEncoderLoader", "inputs": { "model_name": "gemma-3-12b-it-qat-q4_0-unquantized" } }
}
