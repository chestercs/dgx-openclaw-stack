{
  "_metadata": {
    "name": "flux-krea-2k-i2i",
    "description": "FLUX.1-Krea-dev img2img (image-to-image). Takes a SOURCE image (uploaded to ComfyUI input/ via the bridge's `_fetch_and_upload_init_image` helper, filename bound into the LoadImage node) and produces a MODIFIED image guided by the text prompt. Default resolution 1280x720 (16:9), default denoise 0.7 (moderate transform). Same sampler chain as flux-krea-2k T2I — the only differences are: (a) LoadImage(60) + VAEEncode(61) replace EmptySD3LatentImage as the SamplerCustomAdvanced latent_image input, and (b) BasicScheduler's denoise field is bind-target (0.0 = no change, 1.0 = full redraw). Pair with `generate_i2i` MCP tool. NSFW: use flux-krea-2k-i2i-adult instead.",
    "checkpoint_required": false,
    "defaults": {
      "steps": 30,
      "cfg": 3.5,
      "sampler": "euler",
      "scheduler": "simple",
      "width": 1280,
      "height": 720,
      "denoise": 0.7,
      "negative": ""
    },
    "targets": {
      "prompt":     {"node": "10", "input": "text"},
      "negative":   {"node": "11", "input": "text"},
      "width":      {"node": "21", "input": "width"},
      "height":     {"node": "21", "input": "height"},
      "seed":       {"node": "30", "input": "noise_seed"},
      "steps":      {"node": "31", "input": "steps"},
      "cfg":        {"node": "12", "input": "guidance"},
      "sampler":    {"node": "32", "input": "sampler_name"},
      "scheduler":  {"node": "31", "input": "scheduler"},
      "init_image": {"node": "60", "input": "image"},
      "denoise":    {"node": "31", "input": "denoise"}
    }
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "flux1-krea-dev.safetensors", "weight_dtype": "fp8_e4m3fn"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"}
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "12": {
    "class_type": "FluxGuidance",
    "inputs": {"guidance": 3.5, "conditioning": ["10", 0]}
  },
  "13": {
    "class_type": "ConditioningZeroOut",
    "inputs": {"conditioning": ["11", 0]}
  },
  "21": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "model": ["1", 0],
      "max_shift": 1.15,
      "base_shift": 0.5,
      "width": 1280,
      "height": 720
    }
  },
  "30": {
    "class_type": "RandomNoise",
    "inputs": {"noise_seed": 0}
  },
  "31": {
    "class_type": "BasicScheduler",
    "inputs": {"scheduler": "simple", "steps": 30, "denoise": 0.7, "model": ["21", 0]}
  },
  "32": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler"}
  },
  "33": {
    "class_type": "BasicGuider",
    "inputs": {"model": ["21", 0], "conditioning": ["12", 0]}
  },
  "34": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise":         ["30", 0],
      "guider":        ["33", 0],
      "sampler":       ["32", 0],
      "sigmas":        ["31", 0],
      "latent_image":  ["61", 0]
    }
  },
  "40": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["34", 0], "vae": ["3", 0]}
  },
  "50": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "openclaw-bridge/flux-krea-2k-i2i", "images": ["40", 0]}
  },
  "60": {
    "class_type": "LoadImage",
    "inputs": {"image": "REPLACE_AT_BIND.png", "upload": "image"}
  },
  "61": {
    "class_type": "VAEEncode",
    "inputs": {"pixels": ["60", 0], "vae": ["3", 0]}
  }
}
