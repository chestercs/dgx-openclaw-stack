{
  "_metadata": {
    "name": "ltx-2.3-i2v",
    "description": "LTX-Video 2.3 image-to-video with native audio. The bridge's `comfyui_image__generate_video` tool routes here automatically when `init_image_url` or `init_image_base64` is passed; the bridge uploads the source frame to ComfyUI's input/ dir and binds the resulting filename to this workflow's LoadImage node. To activate: replace the placeholder nodes below with an API-format export of Lightricks' reference i2v workflow (see workflows/README.md → 'LTX-Video 2.3 templates'), then tune the `targets` table to match your exported node IDs.",
    "kind": "video",
    "checkpoint_required": false,
    "defaults": {
      "width": 512,
      "height": 768,
      "length": 96,
      "fps": 24,
      "negative": ""
    },

    "//": "TARGETS TABLE — bridge param → (node id, input key)",
    "//comment-prompt":      "Positive CLIPTextEncode driven by LTXAVTextEncoderLoader's output.",
    "//comment-negative":    "Negative CLIPTextEncode.",
    "//comment-width":       "EmptyLTXVLatentVideo.width (sets target video resolution; the init image gets resized to this).",
    "//comment-height":      "EmptyLTXVLatentVideo.height",
    "//comment-length":      "EmptyLTXVLatentVideo.length",
    "//comment-fps":         "LTXVConditioning.fps or frame_rate, depending on your export.",
    "//comment-seed":        "RandomNoise.noise_seed",
    "//comment-init_image":  "LoadImage.image — the filename the bridge writes via /upload/image. The bridge POSTs to ComfyUI's input/ dir as `openclaw-<8charhex>-<original_basename>` and binds that string here. The LoadImage node downstream uses it.",

    "targets": {
      "prompt":         { "node": "REPLACE_ME_POS_CLIP_NODE_ID",  "input": "text" },
      "negative":       { "node": "REPLACE_ME_NEG_CLIP_NODE_ID",  "input": "text" },
      "width":          { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "width" },
      "height":         { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "height" },
      "length":         { "node": "REPLACE_ME_EMPTY_LATENT_NODE_ID", "input": "length" },
      "fps":            { "node": "REPLACE_ME_LTX_CONDITIONING_NODE_ID", "input": "fps" },
      "seed":           { "node": "REPLACE_ME_RANDOM_NOISE_NODE_ID", "input": "noise_seed" },
      "init_image":     { "node": "REPLACE_ME_LOAD_IMAGE_NODE_ID", "input": "image" }
    }
  },

  "//": "Replace the block below with an API-format export of Lightricks' i2v reference workflow, then update the `targets` above with the actual node IDs. See workflows/README.md → 'LTX-Video 2.3 templates' for the full operator recipe.",

  "REPLACE_ME_POS_CLIP_NODE_ID":  { "class_type": "CLIPTextEncode",         "inputs": { "text": "placeholder positive prompt",  "clip": ["REPLACE_ME_TEXT_ENCODER_LOADER", 0] } },
  "REPLACE_ME_NEG_CLIP_NODE_ID":  { "class_type": "CLIPTextEncode",         "inputs": { "text": "",                              "clip": ["REPLACE_ME_TEXT_ENCODER_LOADER", 0] } },
  "REPLACE_ME_EMPTY_LATENT_NODE_ID":     { "class_type": "EmptyLTXVLatentVideo", "inputs": { "width": 512, "height": 768, "length": 96, "batch_size": 1 } },
  "REPLACE_ME_LTX_CONDITIONING_NODE_ID": { "class_type": "LTXVConditioning",      "inputs": { "positive": ["REPLACE_ME_POS_CLIP_NODE_ID", 0], "negative": ["REPLACE_ME_NEG_CLIP_NODE_ID", 0], "frame_rate": 24 } },
  "REPLACE_ME_RANDOM_NOISE_NODE_ID":     { "class_type": "RandomNoise",           "inputs": { "noise_seed": 0 } },
  "REPLACE_ME_LOAD_IMAGE_NODE_ID":       { "class_type": "LoadImage",             "inputs": { "image": "placeholder.png", "upload": "image" } },
  "REPLACE_ME_TEXT_ENCODER_LOADER":      { "class_type": "LTXAVTextEncoderLoader", "inputs": { "model_name": "gemma-3-12b-it-qat-q4_0-unquantized" } }
}
