{
  "_metadata": {
    "name": "flux-krea-4k-adult-realism",
    "description": "Max adult realism: FLUX.1-Krea-dev native 1536x1536 + flux-uncensored-v2 LoRA (@ 0.7) + super-realism (@ 0.5) + flux-realism-xlabs (@ 0.3) → 4x-UltraSharp ESRGAN preprocess → Ultimate SD Upscale FLUX low-denoise tile pass → ~4K. The realism LoRAs counter the uncensored model's tendency toward 'rubbery skin' and push pore/skin-detail back to photo-realistic levels. NOTE — flux-uncensored-v2 weights ship under a non-commercial license; the bridge ships no weights, the operator owns the license posture (see openclaw-image-comfyui/README.md → 'Content & license posture'). Originally designed around the kijai/ComfyUI-SUPIR diffusion-restoration upscaler, but SUPIR_conditioner currently fails on ComfyUI 0.12+ with 'Cannot copy out of meta tensor'; the Ultimate SD Upscale tile pass is the verified working alternative.",
    "checkpoint_required": false,
    "defaults": {
      "steps": 30,
      "cfg": 3.5,
      "sampler": "euler",
      "scheduler": "simple",
      "width": 1536,
      "height": 1536,
      "batch_size": 1,
      "negative": "deformed, blurry, lowres, watermark, extra fingers, cartoon, anime, painting, illustration, oversaturated, bad anatomy, rubbery skin, plastic skin, doll-like"
    },
    "targets": {
      "prompt":     {"node": "10", "input": "text"},
      "negative":   {"node": "11", "input": "text"},
      "width":      {"node": "20", "input": "width"},
      "height":     {"node": "20", "input": "height"},
      "batch_size": {"node": "20", "input": "batch_size"},
      "seed":       {"node": "30", "input": "noise_seed"},
      "steps":      {"node": "31", "input": "steps"},
      "cfg":        {"node": "12", "input": "guidance"},
      "sampler":    {"node": "32", "input": "sampler_name"},
      "scheduler":  {"node": "31", "input": "scheduler"}
    }
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "flux1-krea-dev.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"}
  },
  "5": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {"model": ["1", 0], "lora_name": "flux-uncensored-v2.safetensors", "strength_model": 0.7}
  },
  "6": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {"model": ["5", 0], "lora_name": "super-realism.safetensors", "strength_model": 0.5}
  },
  "7": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {"model": ["6", 0], "lora_name": "flux-realism-xlabs.safetensors", "strength_model": 0.3}
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "12": {
    "class_type": "FluxGuidance",
    "inputs": {"guidance": 3.5, "conditioning": ["10", 0]}
  },
  "13": {
    "class_type": "ConditioningZeroOut",
    "inputs": {"conditioning": ["11", 0]}
  },
  "20": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": 1536, "height": 1536, "batch_size": 1}
  },
  "21": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "model": ["7", 0],
      "max_shift": 1.15,
      "base_shift": 0.5,
      "width": 1536,
      "height": 1536
    }
  },
  "30": {
    "class_type": "RandomNoise",
    "inputs": {"noise_seed": 0}
  },
  "31": {
    "class_type": "BasicScheduler",
    "inputs": {"scheduler": "simple", "steps": 30, "denoise": 1.0, "model": ["21", 0]}
  },
  "32": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler"}
  },
  "33": {
    "class_type": "BasicGuider",
    "inputs": {"model": ["21", 0], "conditioning": ["12", 0]}
  },
  "34": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise":         ["30", 0],
      "guider":        ["33", 0],
      "sampler":       ["32", 0],
      "sigmas":        ["31", 0],
      "latent_image":  ["20", 0]
    }
  },
  "40": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["34", 0], "vae": ["3", 0]}
  },
  "80": {
    "class_type": "UpscaleModelLoader",
    "inputs": {"model_name": "4x-UltraSharp.pth"}
  },
  "81": {
    "class_type": "UltimateSDUpscale",
    "inputs": {
      "image":             ["40", 0],
      "model":             ["21", 0],
      "positive":          ["12", 0],
      "negative":          ["13", 0],
      "vae":               ["3", 0],
      "upscale_by":        2.5,
      "seed":              0,
      "steps":             20,
      "cfg":               3.5,
      "sampler_name":      "euler",
      "scheduler":         "simple",
      "denoise":           0.35,
      "upscale_model":     ["80", 0],
      "mode_type":         "Linear",
      "tile_width":        1024,
      "tile_height":       1024,
      "mask_blur":         8,
      "tile_padding":      32,
      "seam_fix_mode":     "None",
      "seam_fix_denoise":  0.0,
      "seam_fix_width":    0,
      "seam_fix_mask_blur":0,
      "seam_fix_padding":  0,
      "force_uniform_tiles": true,
      "tiled_decode":      true,
      "batch_size":        1
    }
  },
  "90": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "openclaw-bridge/flux-krea-4k-adult-realism", "images": ["81", 0]}
  }
}
