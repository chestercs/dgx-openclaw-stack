{
  "_metadata": {
    "name": "flux-krea-2k",
    "description": "FLUX.1-Krea-dev single-stage photorealism. Default resolution 1280x720 (16:9 widescreen, ~30s render on warm GB10). Pass width=2048 height=2048 to render at 2K square (~4 min). Recommended default workflow for the bundle — the upscaled-to-4K variants (flux-krea-4k-supir / 4k-tiled / 4k-adult / 4k-adult-realism) currently produce visible UltimateSDUpscale tile-seam artifacts on FLUX latents and are not recommended; the single-stage path here is artifact-free at any res FLUX can produce natively (typically up to 2K square or 1920x1088). Uses the recommended FLUX sampler chain (ModelSamplingFlux + SamplerCustomAdvanced) with width/height kept in lockstep across EmptyLatent and ModelSamplingFlux for correct sigma scheduling. Requires FLUX-Krea-dev UNet, t5xxl_fp16 + clip_l, and ae.safetensors (see docs/reference/image-comfyui-bridge.md → 'Recommended model bundle').",
    "checkpoint_required": false,
    "defaults": {
      "steps": 30,
      "cfg": 3.5,
      "sampler": "euler",
      "scheduler": "simple",
      "width": 1280,
      "height": 720,
      "batch_size": 1,
      "negative": ""
    },
    "targets": {
      "prompt":     {"node": "10", "input": "text"},
      "negative":   {"node": "11", "input": "text"},
      "width":      [
        {"node": "20", "input": "width"},
        {"node": "21", "input": "width"}
      ],
      "height":     [
        {"node": "20", "input": "height"},
        {"node": "21", "input": "height"}
      ],
      "batch_size": {"node": "20", "input": "batch_size"},
      "seed":       {"node": "30", "input": "noise_seed"},
      "steps":      {"node": "31", "input": "steps"},
      "cfg":        {"node": "12", "input": "guidance"},
      "sampler":    {"node": "32", "input": "sampler_name"},
      "scheduler":  {"node": "31", "input": "scheduler"}
    }
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "flux1-krea-dev.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"}
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "12": {
    "class_type": "FluxGuidance",
    "inputs": {"guidance": 3.5, "conditioning": ["10", 0]}
  },
  "13": {
    "class_type": "ConditioningZeroOut",
    "inputs": {"conditioning": ["11", 0]}
  },
  "20": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": 1280, "height": 720, "batch_size": 1}
  },
  "21": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "model": ["1", 0],
      "max_shift": 1.15,
      "base_shift": 0.5,
      "width": 1280,
      "height": 720
    }
  },
  "30": {
    "class_type": "RandomNoise",
    "inputs": {"noise_seed": 0}
  },
  "31": {
    "class_type": "BasicScheduler",
    "inputs": {"scheduler": "simple", "steps": 30, "denoise": 1.0, "model": ["21", 0]}
  },
  "32": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler"}
  },
  "33": {
    "class_type": "BasicGuider",
    "inputs": {"model": ["21", 0], "conditioning": ["12", 0]}
  },
  "34": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise":         ["30", 0],
      "guider":        ["33", 0],
      "sampler":       ["32", 0],
      "sigmas":        ["31", 0],
      "latent_image":  ["20", 0]
    }
  },
  "40": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["34", 0], "vae": ["3", 0]}
  },
  "50": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "openclaw-bridge/flux-krea-2k", "images": ["40", 0]}
  }
}
