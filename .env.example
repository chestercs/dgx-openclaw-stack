# ============================================================================
# DGX OpenClaw Stack — .env template
# ============================================================================
# Copy this file to .env and fill in the placeholder values before running
# `docker compose up -d`. The included bootstrap.sh script can do this for you
# interactively — it's the recommended path for first-time setup.
#
#   cp .env.example .env
#   $EDITOR .env
#   # …or…
#   ./bootstrap.sh
#
# NEVER commit your real .env — it contains API keys and gateway tokens.
# The shipped .gitignore already excludes it.
# ============================================================================


# ----------------------------------------------------------------------------
# Secrets — generate strong random values (the bootstrap.sh script does this
# automatically with `openssl rand -base64 96`). Do NOT leave the placeholders.
# ----------------------------------------------------------------------------

# Shared API key for both vLLM services (LLM + embedding). The OpenClaw gateway
# uses this as its OPENAI_API_KEY when calling vllm-llm, and the patch-config
# script writes it into the memorySearch remote.apiKey for bge-m3.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
VLLM_API_KEY=CHANGE_ME_run_openssl_rand_base64_64

# OpenClaw gateway authentication token. Required to pair the Chrome extension
# or CLI with the gateway. Treat like a password.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# SearxNG cookie / CSRF signing key. SearxNG refuses to start with the shipped
# upstream placeholder. The bootstrap script generates a 64-char random value
# automatically; set it manually with `openssl rand -base64 64` if editing by hand.
SEARXNG_SECRET=CHANGE_ME_run_openssl_rand_base64_64

# Your HuggingFace access token. Needed for the initial model download.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
# The Gemma 4 31B-IT-NVFP4 model is gated — you must accept the license at
# https://huggingface.co/nvidia/Gemma-4-31B-IT-NVFP4 with the same HF account.
# Default empty: bootstrap.sh will prompt for it on first run.
HUGGING_FACE_HUB_TOKEN=

# Bearer token the openclaw-tts-router accepts on /v1/audio/speech. The
# OpenClaw gateway passes this in the openai TTS provider's apiKey field.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
# To opt out of TTS entirely: leave empty AND park openclaw-tts-en /
# openclaw-tts-router with `profiles: ["never"]` in docker-compose.yml. The
# patcher's TTS step (11) is env-gated and skips cleanly when this is unset.
OPENCLAW_TTS_ROUTER_API_KEY=CHANGE_ME_run_openssl_rand_base64_64

# Bearer token the openclaw-tts-en (Kokoro) backend accepts. The router uses
# the same value internally as EN_API_TOKEN, so one secret covers both hops.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
TTS_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# Bearer token the openclaw-stt-whisper (faster-whisper large-v3) backend
# accepts on /v1/audio/transcriptions and /v1/audio/translations. Patcher
# step 14 writes this into tools.media.audio.models[].headers.Authorization
# as `Bearer <token>`, so the STT auth does NOT collide with any global
# models.providers.openai.apiKey you may have for a cloud OpenAI account.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
# To opt out of STT entirely: leave empty AND park openclaw-stt-whisper with
# `profiles: ["never"]` in docker-compose.yml. The patcher's STT step skips
# cleanly when this is unset.
STT_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# Bearer token the openclaw-browser FastAPI management API accepts on
# /v1/sessions/* and /v1/extract. Also URL-embedded as `?token=<...>` in the
# browser.profiles.<name>.cdpUrl entries written by patcher step 15 — that
# is the only auth surface OpenClaw's cdpUrl config field supports.
# Recommended: 48+ chars of url-safe random — `openssl rand -base64 48`.
# To opt out of browser automation entirely: leave empty AND drop `browser`
# from COMPOSE_PROFILES. Patcher step 15 skips cleanly when this is unset.
BROWSER_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_48


# ----------------------------------------------------------------------------
# Host paths (required)
#
# Absolute paths on the host where persistent data lives. The compose file
# bind-mounts these into the containers.
# ----------------------------------------------------------------------------

# HuggingFace cache — the ~16 GB Gemma weights + ~1 GB bge-m3 weights land here.
# Put this on your fastest local disk. Not on NFS.
VLLM_HF_CACHE_DIR=/opt/dgx-openclaw/hf-cache

# Docker volume label for the HF cache. Two reasons to override the default:
#   1. Sibling LLM stacks (alternate quantizations / experimental embed models)
#      that bind-mount the SAME VLLM_HF_CACHE_DIR on this host can share one
#      consistent volume label in `docker volume ls`.
#   2. Avoid colliding with another dgx-openclaw-stack instance on the same host.
# Bridge DNS reachability of services is unaffected — only the volume label.
VLLM_HF_CACHE_VOLUME_NAME=dgx-openclaw-hf-cache

# OpenClaw config dir — holds openclaw.json, memory/, heartbeat journals, etc.
# Back up regularly; this is your agent's long-term memory.
OPENCLAW_CONFIG_DIR=/opt/dgx-openclaw/openclaw-config

# OpenClaw workspace dir — the working directory the agent operates on.
# This is what the agent reads/writes when you tell it to edit files. Typically
# a git repo you want to let the agent work inside.
OPENCLAW_WORKSPACE_DIR=/opt/dgx-openclaw/workspace


# ----------------------------------------------------------------------------
# vLLM — Gemma 4 31B NVFP4 tuning
# ----------------------------------------------------------------------------

# Fraction of unified GPU memory reserved for the LLM. Default 0.68 leaves ~9 GB
# for the embedding stack and ~15 GB of host headroom for OS + Docker + misc.
# - 0.68: safe default with embedding stack running (≈58 GB KV cache).
# - 0.85: if you're NOT running the embedding service (≈86 GB KV cache).
# Do NOT exceed 0.90 on 128 GB unified memory — you'll starve the OS.
LLM_GPU_MEM_UTIL=0.68

# Max model context (tokens). 262144 = 256K, the Gemma 4 architecture maximum.
# Lower values save KV cache reservation but disable long-context workflows.
LLM_MAX_MODEL_LEN=262144

# Max concurrent sequences (continuous batching width). 2 is the sweet spot on
# a 128 GB GB10 with 0.68 util — supports two 110K-context chats preempt-free.
# Going higher requires raising LLM_GPU_MEM_UTIL (and therefore disabling the
# embedding stack or accepting smaller effective context per user).
LLM_MAX_NUM_SEQS=2


# ----------------------------------------------------------------------------
# vLLM — bge-m3 embedding tuning
# ----------------------------------------------------------------------------

# bge-m3 is tiny (~1.1 GB BF16). 0.03 is plenty and keeps the KV budget for Gemma.
EMBED_GPU_MEM_UTIL=0.03

# bge-m3 native context is 8K. No reason to lower — the embedding model doesn't
# allocate KV the way an autoregressive LLM does.
EMBED_MAX_MODEL_LEN=8192

# Max concurrent embedding requests. 2 matches the LLM concurrency.
EMBED_MAX_NUM_SEQS=2


# ----------------------------------------------------------------------------
# OpenClaw gateway
# ----------------------------------------------------------------------------

# Host port for the gateway's main Web UI + WebSocket RPC. Put this behind a
# reverse proxy (Nginx Proxy Manager, Caddy, Traefik) for internet access.
OPENCLAW_GATEWAY_PORT=18789

# Host port for the gateway's secondary control endpoint.
OPENCLAW_GATEWAY_CONTROL_PORT=18790

# Gateway bind mode:
#   - lan:     listen on 0.0.0.0 (accessible from LAN and host). Default.
#   - local:   listen on 127.0.0.1 only (container-local; must use a reverse
#              proxy that shares the network namespace).
OPENCLAW_GATEWAY_BIND=lan

# If you access the gateway directly from your LAN (bypassing any CDN/reverse
# proxy), add your LAN CIDR here so X-Forwarded-For audit passes. Leave empty
# if all access goes through a reverse proxy.
# Example: OPENCLAW_LAN_CIDR=192.168.1.0/24
OPENCLAW_LAN_CIDR=

# If your reverse proxy terminates TLS and the gateway sees plaintext ws://
# connections from the proxy, set this to 1. Required for Nginx Proxy Manager
# in front of a private-IP gateway.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1


# ----------------------------------------------------------------------------
# OpenClaw heartbeat — proactive agent check-ins
# ----------------------------------------------------------------------------

# Active hours (inclusive). Outside this window the heartbeat does not wake up
# — saves idle vLLM prefills overnight. Start > End wraps around midnight.
OPENCLAW_HEARTBEAT_ACTIVE_START=09:00
OPENCLAW_HEARTBEAT_ACTIVE_END=02:00

# IANA timezone for both heartbeat.activeHours AND dreaming.frequency.
# Examples: America/Los_Angeles, Europe/Berlin, Asia/Tokyo, UTC.
OPENCLAW_HEARTBEAT_TZ=UTC


# ----------------------------------------------------------------------------
# OpenClaw dreaming (REM-style memory consolidation)
# ----------------------------------------------------------------------------

# Default 1: nightly memory consolidation enabled (light/deep/rem phases).
# Requires an OpenClaw image >= 2026.4.15 — this is the current stable. Set to
# 0 if you're pinned to an older gateway tag (older versions reject the
# memory-core plugin schema).
OPENCLAW_ENABLE_DREAMING=1


# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------

# Docker Compose project name. Scopes docker-managed resources (default bridge,
# auto-generated volumes, etc.) to this project so multiple stacks can coexist
# on one host. Does NOT affect the container names shown in `docker ps` — those
# are controlled by CONTAINER_NAME_PREFIX below.
COMPOSE_PROJECT_NAME=dgx-openclaw

# Prefix prepended to every container name. Default empty → bare names like
# `vllm-llm`, `openclaw-gateway` in `docker ps`. Set to a prefix (e.g. `dgx-`)
# if you're running multiple stacks on one host and want namespace isolation
# (`dgx-vllm-llm`, `dgx-openclaw-gateway`, …). Does NOT affect bridge DNS
# reachability of sibling containers — those resolve by the compose service
# name (`vllm-llm`, `searxng`, `openclaw-gateway`) regardless of the
# container_name value.
CONTAINER_NAME_PREFIX=

# vLLM log verbosity (ERROR / WARNING / INFO / DEBUG).
VLLM_LOGGING_LEVEL=INFO

# Default container timezone for the OpenClaw services.
TZ=UTC

# OpenClaw gateway image ref. The compose file embeds this after the bare
# image name (`ghcr.io/openclaw/openclaw`) for all three openclaw-{config-
# init,gateway,cli} services, so the value MUST include its own qualifier:
#   - `:<tag>` — e.g. `:latest` (moving target) or `:2026.4.15`
#   - `@<digest>` — e.g. `@sha256:9d5f1dfb...` (immutable, reproducible)
#
# Docker tag grammar forbids colons inside a tag, so a bare
# `sha256:…` value produces `invalid reference format`. Use `@sha256:…`
# for digest pins.
#
# Default `:latest` pulls the newest stable gateway on every
# `docker compose pull` (convenient, implicit upgrades); pin to a digest
# for reproducible deploys that no `pull` can drift. Examples:
#
#   OPENCLAW_IMAGE_REF=:latest
#   OPENCLAW_IMAGE_REF=:2026.4.22
#   OPENCLAW_IMAGE_REF=@sha256:639fc648f1e2cb9137cd2d4513038e3b5efdebc94a6bd7fbef42c908005945f4
#
# Upgrade runbook (pull, verify, rollback) in `docs/CUSTOMIZATION.md`.
# OPENCLAW_IMAGE_REF=:latest


# ----------------------------------------------------------------------------
# TTS — Kokoro 82M (English, default) + optional F5-TTS (Hungarian, opt-in)
#
# The English TTS surface is enabled by default once OPENCLAW_TTS_ROUTER_API_KEY
# and TTS_API_TOKEN above are set (the bootstrap script generates both). English
# (Kokoro 82M, Apache 2.0) ships in this stack as the openclaw-tts-en service.
# Coexists with the Gemma 4 NVFP4 LLM on the same GB10 GPU (~500 MB - 1 GB VRAM).
#
# Default Kokoro voice the router falls back to when the request omits one.
# A-grade alternates: af_bella (US female), bf_emma (UK female), am_michael
# (US male), af_nicole (US female, headphones trait).
# TTS_EN_DEFAULT_VOICE=af_heart

# Default voice id the gateway sets on outgoing TTS requests (read by patcher
# step 11 → messages.tts.providers.openai.voiceId). Usually the same as the
# router default.
# OPENCLAW_TTS_DEFAULT_VOICE=af_heart

# Override KOKORO_DEVICE=cpu to run Kokoro without a GPU (~10× slower; useful
# on a remote-vLLM deployment where this host has no GPU).
# KOKORO_DEVICE=cuda

# Host-side bind for the EN backend (Kokoro). Default 127.0.0.1 = loopback only
# — only this host can hit it (debugging via `curl 127.0.0.1:8091/healthz`).
# The OpenClaw gateway always reaches it via bridge DNS, regardless. Set to
# 0.0.0.0 ONLY if you actively want LAN clients to reach the EN backend
# directly (the service is Bearer-token-protected via TTS_API_TOKEN, but a
# leaked token is still a leaked token).
# TTS_EN_BIND=127.0.0.1
# TTS_EN_PORT=8091

# Host-side bind for the OpenAI-compat router. Same loopback-only default. The
# OpenClaw gateway reaches the router via bridge DNS — set 0.0.0.0 only if a
# LAN client (e.g. a third-party app calling /v1/audio/speech directly) needs
# direct access. Bearer-token-protected via OPENCLAW_TTS_ROUTER_API_KEY.
# TTS_ROUTER_BIND=127.0.0.1
# TTS_ROUTER_PORT=8092

# Leading silence (ms) prepended to every TTS reply via ffmpeg adelay filter.
# F5-TTS emits audio with essentially no leading silence — the first phoneme
# starts at t=0 — which collides with Whisper's ~50-100 ms STT warm-up window
# and the first sound gets dropped (observed as "Szia" -> "Zia" in round-trip
# benchmarks). A 200-400 ms pad gives the STT room to settle. Kokoro EN is
# less affected but the pad is free (<1 ms ffmpeg overhead) and harmless.
# Set to 0 to disable entirely (brings back the onset-clip bug on HU short
# utterances — keep at 300 unless you have a specific reason).
# ROUTER_LEADING_SILENCE_MS=300


# ----------------------------------------------------------------------------
# OPTIONAL: Hungarian TTS — F5-TTS, OPT-IN, CC-BY-NC model weights
#
# Wrapper code is MIT; the bundled model weights (`sarpba/F5-TTS_V1_hun_v2`)
# are CC-BY-NC-4.0 — NON-COMMERCIAL USE ONLY. Building the openclaw-tts-f5hun
# image triggers the HF download and constitutes acceptance of the upstream
# model license. The repo ships no model weights of any kind. For commercial
# use, override F5_CHECKPOINT / F5_VOCAB inside the openclaw-tts-f5hun service
# (see openclaw-tts-f5hun/README.md).
#
# Three independent levers must align to activate the HU service — the
# bootstrap.sh prompts for opt-in and sets all three for you, or you can
# uncomment the lines below by hand:
#   1. F5HUN_API_TOKEN — Bearer token for the HU /v1/audio/speech endpoint
#   2. F5HUN_URL — router → HU backend address (bridge DNS works as-is)
#   3. COMPOSE_PROFILES=hu — activates the openclaw-tts-f5hun service block
#
# Once active, the router exposes the HU voice ids (default_hu, hu_diana) and
# the diacritic-based autodetect: input containing áéíóöőúüű is silently
# re-routed to the HU backend even when the agent asks for an English default
# voice — keeps Hungarian phonetics from being mangled by the English G2P.
# ----------------------------------------------------------------------------
# F5HUN_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64
# F5HUN_URL=http://openclaw-tts-f5hun:8080/v1/audio/speech
# COMPOSE_PROFILES=hu

# Default voice the HU backend uses when a request omits one. The bundled
# `default_hu` is built from a public-domain LibriVox recording (Diana
# Majlinger reading from Géza Gárdonyi's "Egri csillagok" — a 19th-century
# Hungarian historical novel). Drop your own <name>.wav + <name>.txt into the
# tts-f5hun-voices Docker volume to add cloned voices.
# F5HUN_DEFAULT_VOICE=default_hu

# Voice the router re-routes to when HU autodetect fires. Only effective when
# all three F5HUN_* opt-in vars above are set.
# TTS_HU_AUTOROUTE_VOICE=default_hu

# Override F5HUN_DEVICE=cpu to run F5-TTS without a GPU (much slower; useful
# on a remote-vLLM deployment where this host has no GPU).
# F5HUN_DEVICE=cuda

# Host-side bind for the HU backend (F5-TTS). Same loopback-only default as
# the EN service. Bearer-token-protected via F5HUN_API_TOKEN. The router
# reaches this via bridge DNS regardless of the binding.
# TTS_F5HUN_BIND=127.0.0.1
# TTS_F5HUN_PORT=8090


# ----------------------------------------------------------------------------
# STT — faster-whisper large-v3 (English + Hungarian, autodetect)
#
# The STT surface is enabled by default once STT_API_TOKEN above is set (the
# bootstrap script generates it). Model: MIT-licensed Whisper large-v3 served
# by a ~150 LOC FastAPI wrapper around faster-whisper, built from
# ./openclaw-stt-whisper/server/ on a CUDA 13 base (see that folder's
# README.md for why we self-build instead of using the speaches upstream
# image — in short: Blackwell sm_120 compute-kernel compat). Whisper
# autodetects the input language per request, so no bilingual router is
# needed. FLEURS Hungarian WER 14.1%.
#
# OpenClaw consumption: patcher step 14 writes an entry into
# tools.media.audio.models[] pointing here. Consumed by voice-note upload
# (attach a wav/mp3 in the Control UI chat composer), Discord voice channels,
# the VoiceCall CLI, and the Talk / Voicewake node pipelines. The Control UI
# realtime mic button is a separate path — it uses the browser's native Web
# Speech API, which does NOT route through this service.
#
# Budget: ~3 GB VRAM at float16; ~12 GB headroom remains on a 128 GB GB10 with
# LLM_GPU_MEM_UTIL=0.68 and the Kokoro TTS running.
# ----------------------------------------------------------------------------

# HuggingFace model id the backend loads on first request.
# Default (active when this line stays commented): Trendency/whisper-large-v3-hu
#   Hungarian Whisper fine-tune, Apache-2.0, ~11% CV WER. Validated on
#   GB10 against vanilla large-v3:
#     - Hungarian: ~7-8 fewer mis-hearings per chapter (János Vitéz
#       LibriVox); survives telephone-bandpass + pink noise degradation
#       with minimal extra errors.
#     - English: identical output on the JFK 11-sec reference clip —
#       no degradation observed on bilingual workloads at smoke scale.
#   First-boot HF download + CT2 float16 conversion is ~3 min (cached in
#   the stt-whisper-hf-cache volume thereafter).
#
# Override with the pure multilingual baseline if your workload is
# English-heavy and you want maximum-safety on unseen English:
# STT_WHISPER_MODEL=Systran/faster-whisper-large-v3
#
# Any HuggingFace Whisper repo id works — the wrapper auto-detects
# non-CT2 repos and converts them to CT2 float16 on first boot.
# Example (community fine-tune with a cleaner train/eval split):
# STT_WHISPER_MODEL=Trendency/whisper-large-v3-hu
#
# Swap is reversible. Converted CT2 artefacts coexist in the HF volume,
# so flipping back and forth between tested models is instant (no
# re-download, no re-convert).

# Inference precision. CTranslate2 on Blackwell (sm_120) may reject some
# low-precision kernel classes even on a CUDA 13 build — if the first
# transcribe raises a `ValueError: target device or backend do not support
# efficient X computation`, fall through the ladder in this order:
#   1. float16 (default, ~3 GB VRAM, full quality).
#   2. bfloat16 (same speed class, numerically more robust on newer HW).
#   3. int8_float16 (~1.5 GB VRAM, 5-10% WER cost).
#   4. int8_bfloat16 (same VRAM as above, alternate kernel class).
#   5. int8 (slow on GPU; reliable fallback).
#   6. float32 (~6 GB VRAM, slowest but no quantization — lossless baseline).
# STT_WHISPER_COMPUTE_TYPE=float16

# Device to run inference on. `cuda` (default) for GPU; `cpu` on a GPU-less
# host (e.g. a remote-vLLM deployment — ~50× slower, realistic only for short
# voice notes).
# STT_WHISPER_DEVICE=cuda

# Turbo alternate (8× faster, ~1.6 GB VRAM, ~equal EN WER). Hungarian WER is
# NOT independently published for the turbo variant — run your own HU samples
# through both and compare before switching in production use:
# STT_WHISPER_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Host-side bind for the STT backend. Default 127.0.0.1 = loopback only (LAN
# cannot reach it — debug via `curl 127.0.0.1:8093/health`). The OpenClaw
# gateway always reaches it via bridge DNS, regardless. Set to 0.0.0.0 ONLY
# if you actively want LAN clients to POST /v1/audio/transcriptions directly
# (still Bearer-protected via STT_API_TOKEN, but a leaked token is a leaked
# token — keep the loopback default unless you have a reason).
# STT_WHISPER_BIND=127.0.0.1
# STT_WHISPER_PORT=8093

# Gateway wiring (consumed by openclaw-config-init step 14):
# OpenClaw convention is trailing-slash on baseUrl — the patcher appends one
# if missing, so either form works.
# OPENCLAW_STT_BASE_URL=http://openclaw-stt-whisper:8080/v1
# OPENCLAW_STT_MODEL=Systran/faster-whisper-large-v3
# OPENCLAW_STT_LANGUAGE=           # empty = Whisper autodetects the language


# ----------------------------------------------------------------------------
# Optional: remote vLLM / cloud LLM backend
#
# By default the gateway, config patcher, and CLI all reach the in-compose
# vllm-llm and vllm-embedding services by their bridge-DNS names. If you'd
# rather host the heavy LLM (and/or embedding) on a different machine — a
# remote DGX over LAN, a cloud OpenAI-compatible endpoint (Bedrock proxy,
# OpenRouter, vLLM-on-RunPod, …) — uncomment the three vars below and add
# `profiles: ["never"]` to vllm-llm + vllm-embedding in docker-compose.yml so
# they don't try to spin up locally.
#
# All three must be reachable from inside the openclaw-gateway container.
# The remote vLLM API key still uses VLLM_API_KEY above.
#
# Full walkthrough: docs/CUSTOMIZATION.md → "Run with a remote vLLM backend".
# ----------------------------------------------------------------------------
# OPENAI_BASE_URL=https://your-remote-vllm.example.com/v1
# LLM_BASE_URL=https://your-remote-vllm.example.com/v1/
# EMBED_BASE_URL=https://your-remote-embed.example.com/v1/


# ----------------------------------------------------------------------------
# Optional: Discord voice-controlled agent (OPT-IN)
#
# Lets you join an OpenClaw-controlled bot to a Discord voice channel and
# drive an agent by voice: speak a request, the Whisper STT above transcribes
# it, the agent plans + executes tools, the TTS above speaks the reply back
# into the channel.
#
# ISOLATION POSTURE (important): the Discord agent is intended to run in a
# SEPARATE workspace from your main agent, so that anyone with access to the
# bound Discord channel cannot extract memory notes, chat history, or
# personal files from your primary workspace. This is enforced at
# `openclaw agents add` time via a dedicated workspace path — see
# docs/CUSTOMIZATION.md → "Voice-controlled agent over Discord" for the full
# isolation + exec-policy setup.
#
# Three independent levers must align to bring this online:
#   1. DISCORD_BOT_TOKEN — your bot's secret, from the Discord Developer
#      Portal (Applications → your app → Bot → Reset Token). Treat like a
#      password. Leaking it lets anyone control your bot.
#   2. A dedicated isolated agent — `openclaw agents add` with its own
#      --workspace path (NOT the shared ~/.openclaw/workspace/). See the
#      runbook in docs/CUSTOMIZATION.md.
#   3. Channel → agent binding — `openclaw agents bind` routes the Discord
#      channel's incoming voice/text traffic to the isolated agent.
# ----------------------------------------------------------------------------

# Bot token from https://discord.com/developers/applications — paste the
# "Reset Token" output here. Empty = Discord integration disabled. The
# patcher will not create or modify `channels.discord.*` while this is empty.
# Never made a Discord bot before? Full portal walkthrough (permissions,
# intents, server invite) in docs/discord-bot-setup.md.
# DISCORD_BOT_TOKEN=

# Name of the isolated agent that handles Discord voice traffic. The setup
# runbook creates this agent via `openclaw agents add ${DISCORD_AGENT_NAME}
# --workspace ${DISCORD_WORKSPACE_DIR}`. Keep it distinct from "main" so that
# exec-policy, memory sources, and tool scopes are separately tunable.
# DISCORD_AGENT_NAME=discord-voice

# Host path for the Discord agent's ISOLATED workspace. Must NOT overlap
# with OPENCLAW_WORKSPACE_DIR — that is where your personal memory lives.
# The bootstrap script does not create this directory automatically; the
# runbook includes the mkdir step.
# DISCORD_WORKSPACE_DIR=/opt/openclaw/workspace-discord

# Optional: auto-join a specific Discord guild + voice channel at gateway
# startup. Both must be numeric Discord snowflake IDs (enable Developer Mode
# in Discord → right-click guild/channel → "Copy ID"). Leave empty for
# manual-join-on-demand via the `/vc join` slash command.
# DISCORD_AUTOJOIN_GUILD_ID=
# DISCORD_AUTOJOIN_VOICE_CHANNEL_ID=


# ----------------------------------------------------------------------------
# Browser automation — Playwright Chromium via Chrome DevTools Protocol
# (OPT-IN, profile=browser)
#
# OpenClaw's built-in `browser` tool attaches to a self-hosted Chromium
# cluster running in the openclaw-browser container. Each onboarded
# credential gets its own warm Chromium with persistent user-data-dir
# (cookies survive restart for ~14d GitHub / ~30d Notion / etc.). 1x manual
# OAuth onboarding via headful Chromium + noVNC — see
# `./bootstrap-browser-login.sh <profile-name>`.
#
# Three independent levers must align to bring this online (mirrors the
# Hungarian-TTS opt-in pattern):
#   1. BROWSER_API_TOKEN — generated by bootstrap.sh on explicit opt-in.
#   2. The `browser` Compose profile must be active. Either set
#      `COMPOSE_PROFILES=browser` below (or `hu,browser` if you also opted
#      into HU TTS), or pass `--profile browser` on the docker compose
#      command line.
#   3. At least one onboarded credential — `./bootstrap-browser-login.sh`.
#      For the anonymous default profile, no onboarding step is needed —
#      it boots automatically once the service is up.
#
# Limitations to set expectations:
#   - Passkeys (FIDO2/WebAuthn) DO NOT work over the noVNC bridge —
#     W3C origin-bound spec. Use password+TOTP / SMS OTP. For services
#     that offer long-lived API tokens (GitHub PATs, Notion integration
#     tokens, Linear API keys), use those instead — store the token in
#     a service-specific env var or `.env` line and reach the API
#     directly without the browser at all.
#   - Vanilla Playwright Chromium ships `navigator.webdriver=true`. Fine
#     on user-owned authenticated accounts (GitHub, Notion, Patreon,
#     MediaWiki); will be detected on Cloudflare/DataDome/PerimeterX-
#     fronted hostile sites. No stealth shipped by default. Patchright
#     is documented as a Phase 2 swap if needed.
# ----------------------------------------------------------------------------

# Comma-separated list of named profiles. Maintained by
# ./bootstrap-browser-login.sh — manual edits work but DO NOT reorder
# existing names: each name's port is positional (default=9222, then
# 9223, 9224, …), and reordering would shuffle every cdpUrl in
# openclaw.json on the next patcher run.
# BROWSER_PROFILE_NAMES=

# Host-side bind for the management API (port 9220) AND for the Chromium
# remote-debugging ports (9222-9241). Default 127.0.0.1 = loopback only.
# OpenClaw's gateway always reaches openclaw-browser via bridge DNS at
# `openclaw-browser:9222-9241`, so the host bind is operator-debug only.
# Set BROWSER_BIND=0.0.0.0 ONLY if you want a LAN client to attach
# directly — and only with a header-auth reverse proxy in front, since
# the query-string token is weaker than a bearer header.
# BROWSER_BIND=127.0.0.1
# BROWSER_API_PORT=9220

# Host-side bind for the noVNC port (5901). Same loopback-only default.
# noVNC is only active during the 1x OAuth onboarding window
# (./bootstrap-browser-login.sh) — outside that window the port is idle.
# BROWSER_VNC_BIND=127.0.0.1
# BROWSER_VNC_PORT=5901

# Per-host rate limiter for application-layer browse calls (the
# blocklist + retry safety net). 0.5 rps / 5 burst is a respectful
# default for the public web; bump to 5 rps for your own MediaWiki /
# Notion / GitHub if you find the agent queueing too much.
# BROWSER_RATE_LIMIT_RPS=0.5
# BROWSER_RATE_LIMIT_BURST=5

# Soft cap on warm profiles (matches the published port range
# 9222-9241). Bumping this requires expanding the port range in
# docker-compose.yml as well.
# BROWSER_MAX_PROFILES=20

# Default navigation timeout (ms).
# BROWSER_DEFAULT_TIMEOUT_MS=30000

# Override the docker-compose bridge DNS host the patcher uses when
# building cdpUrls. Useful only if you're routing OpenClaw at the
# browser service through a non-default network alias (rare).
# BROWSER_CDP_HOST=http://openclaw-browser
# BROWSER_PORT_BASE=9222
