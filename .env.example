# ============================================================================
# DGX OpenClaw Stack — .env template
# ============================================================================
# Copy this file to .env and fill in the placeholder values before running
# `docker compose up -d`. The included bootstrap.sh script can do this for you
# interactively — it's the recommended path for first-time setup.
#
#   cp .env.example .env
#   $EDITOR .env
#   # …or…
#   ./bootstrap.sh
#
# NEVER commit your real .env — it contains API keys and gateway tokens.
# The shipped .gitignore already excludes it.
# ============================================================================


# ----------------------------------------------------------------------------
# Secrets — generate strong random values (the bootstrap.sh script does this
# automatically with `openssl rand -base64 96`). Do NOT leave the placeholders.
# ----------------------------------------------------------------------------

# Shared API key for both vLLM services (LLM + embedding). The OpenClaw gateway
# uses this as its OPENAI_API_KEY when calling vllm-llm, and the patch-config
# script writes it into the memorySearch remote.apiKey for bge-m3.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
VLLM_API_KEY=CHANGE_ME_run_openssl_rand_base64_64

# OpenClaw gateway authentication token. Required to pair the Chrome extension
# or CLI with the gateway. Treat like a password.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# SearxNG cookie / CSRF signing key. SearxNG refuses to start with the shipped
# upstream placeholder. The bootstrap script generates a 64-char random value
# automatically; set it manually with `openssl rand -base64 64` if editing by hand.
SEARXNG_SECRET=CHANGE_ME_run_openssl_rand_base64_64

# Your HuggingFace access token. Needed for the initial model download.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
# The default model `nvidia/Gemma-4-26B-A4B-NVFP4` is gated — accept the license
# at https://huggingface.co/nvidia/Gemma-4-26B-A4B-NVFP4 with the same HF account.
# If you switch to the dense alternative, also accept
# https://huggingface.co/nvidia/Gemma-4-31B-IT-NVFP4 — same token works for both.
# Default empty: bootstrap.sh will prompt for it on first run.
HUGGING_FACE_HUB_TOKEN=

# Bearer token the openclaw-tts-router accepts on /v1/audio/speech. The
# OpenClaw gateway passes this in the openai TTS provider's apiKey field.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
# To opt out of TTS entirely: leave empty AND park openclaw-tts-en /
# openclaw-tts-router with `profiles: ["never"]` in docker-compose.yml. The
# patcher's TTS step (11) is env-gated and skips cleanly when this is unset.
OPENCLAW_TTS_ROUTER_API_KEY=CHANGE_ME_run_openssl_rand_base64_64

# Bearer token the openclaw-tts-en (Kokoro) backend accepts. The router uses
# the same value internally as EN_API_TOKEN, so one secret covers both hops.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
TTS_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# TTS auto-attach mode for agent replies. Enum: "always" | "tagged" | "inbound" | "off".
# Default (unset) = "always": every final reply auto-TTS-es. The chat UI is
# hard-wired to the browser's speechSynthesis and ignores this; voice channel
# agents, VoiceCall, AND Discord text-channel agents (v0.11.0+) all use this.
#
# As of v0.11.0 the gateway image ships with ffmpeg via
# `openclaw-base-ext/Dockerfile`, so Discord text-channel TTS-attachment
# works on `always` without any operator workaround. Earlier deploys
# (pre-v0.11.0) had to set this to "tagged" because the upstream gateway
# image ships WITHOUT ffmpeg; the attachment pipeline crashed silently
# with `[discord] final reply failed: Error: ffmpeg not found in trusted
# system directories` and the bot's text payload never landed.
#
# Recommended:
#   - v0.11.0+ deploys: leave this unset (default `always`) — works on all
#     surfaces. Keep `tagged` only if you actively don't want auto-attach.
#   - Pre-v0.11.0 deploys with Discord text-channel agents: keep
#     `OPENCLAW_TTS_AUTO=tagged` until you can rebuild the gateway image.
# OPENCLAW_TTS_AUTO=always

# Bearer token the openclaw-stt-whisper (faster-whisper large-v3) backend
# accepts on /v1/audio/transcriptions and /v1/audio/translations. Patcher
# step 14 writes this into tools.media.audio.models[].headers.Authorization
# as `Bearer <token>`, so the STT auth does NOT collide with any global
# models.providers.openai.apiKey you may have for a cloud OpenAI account.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
# To opt out of STT entirely: leave empty AND park openclaw-stt-whisper with
# `profiles: ["never"]` in docker-compose.yml. The patcher's STT step skips
# cleanly when this is unset.
STT_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# Bearer token the openclaw-browser FastAPI management API accepts on
# /v1/sessions/* and /v1/extract. Also URL-embedded as `?token=<...>` in the
# browser.profiles.<name>.cdpUrl entries written by patcher step 15 — that
# is the only auth surface OpenClaw's cdpUrl config field supports.
# Recommended: 48+ chars of url-safe random — `openssl rand -base64 48`.
# To opt out of browser automation entirely: leave empty AND drop `browser`
# from COMPOSE_PROFILES. Patcher step 15 skips cleanly when this is unset.
BROWSER_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_48


# ----------------------------------------------------------------------------
# Host paths (required)
#
# Absolute paths on the host where persistent data lives. The compose file
# bind-mounts these into the containers.
# ----------------------------------------------------------------------------

# HuggingFace cache — the ~16 GB Gemma weights + ~1 GB bge-m3 weights land here.
# Put this on your fastest local disk. Not on NFS.
VLLM_HF_CACHE_DIR=/opt/dgx-openclaw/hf-cache

# Docker volume label for the HF cache. Two reasons to override the default:
#   1. Sibling LLM stacks (alternate quantizations / experimental embed models)
#      that bind-mount the SAME VLLM_HF_CACHE_DIR on this host can share one
#      consistent volume label in `docker volume ls`.
#   2. Avoid colliding with another dgx-openclaw-stack instance on the same host.
# Bridge DNS reachability of services is unaffected — only the volume label.
VLLM_HF_CACHE_VOLUME_NAME=dgx-openclaw-hf-cache

# OpenClaw config dir — holds openclaw.json, memory/, heartbeat journals, etc.
# Back up regularly; this is your agent's long-term memory.
OPENCLAW_CONFIG_DIR=/opt/dgx-openclaw/openclaw-config

# OpenClaw workspace dir — the working directory the agent operates on.
# This is what the agent reads/writes when you tell it to edit files. Typically
# a git repo you want to let the agent work inside.
OPENCLAW_WORKSPACE_DIR=/opt/dgx-openclaw/workspace


# ----------------------------------------------------------------------------
# vLLM — Gemma 4 26B-A4B MoE NVFP4 tuning (default)
# ----------------------------------------------------------------------------

# vLLM-side served model id. Drives the `--model` flag on the vllm-llm service
# and (implicitly) which checkpoint the OpenClaw agent reaches when it talks to
# port 8004. Default `nvidia/Gemma-4-26B-A4B-NVFP4` (MoE) is the calibrated
# reference profile. The patcher registers both the MoE and the 31B dense entries
# in the OpenClaw catalog regardless of which is running — the active model is
# selected via the OpenClaw UI / per-agent settings, not via .env (the schema
# doesn't expose a writable agents.defaults.llm.model field).
#
# To run a community NVFP4 quant instead (e.g. for a pre-applied loader patch):
#   LLM_MODEL_ID=RedHatAI/gemma-4-26B-A4B-it-NVFP4
#   LLM_QUANTIZATION=compressed-tensors    # match the model's quant scheme
# Then `docker compose up -d --force-recreate vllm-llm`. The patcher auto-adds
# a generic catalog entry for the override id; the OpenClaw UI will list it.
#
# To run the dense 31B alternative:
#   docker compose stop vllm-llm
#   COMPOSE_PROFILES=dense docker compose up -d vllm-llm-dense
# (Leave LLM_MODEL_ID unset — the dense service hard-codes `--model` to the 31B id.)
# LLM_MODEL_ID=

# vLLM `--quantization` flag. Default `modelopt` matches the NVIDIA NVFP4
# checkpoints (Gemma 4 26B-A4B and 31B IT). Community quantizations may use
# `compressed-tensors` (RedHatAI), `awq`, `gptq`, or another scheme — keep
# this in sync with the model config or vLLM throws a pydantic validation
# error on boot ("Quantization method specified in the model config does not
# match the quantization argument").
# LLM_QUANTIZATION=compressed-tensors

# Fraction of unified GPU memory reserved for the LLM. MoE has a smaller working
# set than dense (~16.5 GB model + ~6.6 GB FP8 KV for 2 × 256K), so 0.50 is the
# new safe default — leaves ~64 GB for embedding, ComfyUI, and OS.
# - 0.50: safe default for 2 × 256K-context users with embedding stack running.
# - 0.85: max throughput on a dedicated LLM box (verified at 52 tok/s, ai-muninn
#   GB10 benchmark 2026-04). Park the embedding service first.
# Do NOT exceed 0.90 on 128 GB unified memory — you'll starve the OS.
LLM_GPU_MEM_UTIL=0.50

# MoE routing backend. On Blackwell SM121 (GB10) `marlin` is mandatory: CUTLASS
# produces NaN scale factors on the fused 3D expert tensor format Gemma 4 MoE
# ships. Marlin decompresses FP4 → BF16 at inference time — slightly slower per
# expert but functionally correct. Switch to `cutlass` only on H100/B200 if a
# vLLM upgrade fixes the SM121 path.
LLM_MOE_BACKEND=marlin

# Dense (vllm-llm-dense, port 8005) GPU memory util. The dense 31B NVFP4
# weights take ~31 GB in unified memory (heterogeneous head dim), plus vLLM
# runtime overhead is ~5 GB even in eager mode. 0.40 = ~51 GB cap →
# ~14.5 GB KV pool, fits 1 × 128K request (8.5 GB) with headroom for
# prefix-cache. Drop to 0.35 if you can live with 1 × 64K-ish (tighter);
# bump to 0.50 for 1 × 256K full architecture max.
LLM_GPU_MEM_UTIL_DENSE=0.40

# Dense max-num-seqs. Default 1 (single-user profile). Bump to 2 if you want
# concurrent dense runs at the cost of per-user context room.
LLM_MAX_NUM_SEQS_DENSE=1

# Dense max-model-len. Default 131072 (128K) — chosen for the low-RAM
# single-user profile. The dense 31B NVFP4 weights take ~31 GB on disk and
# in unified memory (heterogeneous head dim 256/512), leaving only ~7 GB KV
# room at LLM_GPU_MEM_UTIL_DENSE=0.30 — exactly enough for 1 × 128K context.
# Bump to 262144 (256K full architecture max) only if you also raise
# LLM_GPU_MEM_UTIL_DENSE to 0.40+ to fit the larger KV reservation
# (~13.5 GB for 1 × 256K).
LLM_MAX_MODEL_LEN_DENSE=131072

# Max model context (tokens). 262144 = 256K, supported by both MoE and dense.
# Lower values save KV cache reservation but disable long-context workflows.
LLM_MAX_MODEL_LEN=262144

# Max concurrent sequences (continuous batching width). 2 × 256K fits comfortably
# in the FP8 KV envelope at LLM_GPU_MEM_UTIL=0.50 (~6.6 GB total KV). Going
# higher is fine on MoE — bandwidth, not memory, becomes the bottleneck — see
# docs/CUSTOMIZATION.md "Tune for your actual concurrency".
LLM_MAX_NUM_SEQS=2

# vLLM `--enforce-eager` flag toggle. Default unset = CUDA graphs ON, which on
# GB10 + Marlin SM121 + MoE 26B-A4B gives ~10% single-stream and ~30% 4-paralel
# aggregate throughput gain over eager mode (verified 2026-05-08, no hangs in a
# 5K-200K context sweep). Set to any non-empty value (e.g. `1`) to force eager
# mode — rollback path if CUDA graphs ever turn unstable on a future vLLM image
# / model combination, or as a back-compat shim for the historical default.
# LLM_ENFORCE_EAGER=

# Host interface the published vLLM port (8004) binds to. Default `127.0.0.1`
# = loopback only (in-host curl + sibling containers). Set to `0.0.0.0` to
# expose the OpenAI-compatible API to the LAN — useful for direct workstation
# clients, remote inference, multi-host setups. The VLLM_API_KEY Bearer is
# the only auth barrier on the published endpoint, so don't flip this on a
# weakly-keyed deploy or one reachable from the public internet.
LLM_BIND=127.0.0.1


# ----------------------------------------------------------------------------
# vLLM — bge-m3 embedding tuning
# ----------------------------------------------------------------------------

# bge-m3 is tiny (~1.1 GB BF16). 0.03 is plenty and keeps the KV budget for Gemma.
EMBED_GPU_MEM_UTIL=0.03

# bge-m3 native context is 8K. No reason to lower — the embedding model doesn't
# allocate KV the way an autoregressive LLM does.
EMBED_MAX_MODEL_LEN=8192

# Max concurrent embedding requests. 2 matches the LLM concurrency.
EMBED_MAX_NUM_SEQS=2


# ----------------------------------------------------------------------------
# OpenClaw gateway
# ----------------------------------------------------------------------------

# Host port for the gateway's main Web UI + WebSocket RPC. Put this behind a
# reverse proxy (Nginx Proxy Manager, Caddy, Traefik) for internet access.
OPENCLAW_GATEWAY_PORT=18789

# Host port for the gateway's secondary control endpoint.
OPENCLAW_GATEWAY_CONTROL_PORT=18790

# Gateway bind mode:
#   - lan:     listen on 0.0.0.0 (accessible from LAN and host). Default.
#   - local:   listen on 127.0.0.1 only (container-local; must use a reverse
#              proxy that shares the network namespace).
OPENCLAW_GATEWAY_BIND=lan

# If you access the gateway directly from your LAN (bypassing any CDN/reverse
# proxy), add your LAN CIDR here so X-Forwarded-For audit passes. Leave empty
# if all access goes through a reverse proxy.
# Example: OPENCLAW_LAN_CIDR=192.168.1.0/24
OPENCLAW_LAN_CIDR=

# If your reverse proxy terminates TLS and the gateway sees plaintext ws://
# connections from the proxy, set this to 1. Required for Nginx Proxy Manager
# in front of a private-IP gateway.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# vLLM idle watchdog timeout (seconds) — patcher step 8 writes this to
# `agents.defaults.llm.idleTimeoutSeconds`. Catches stuck LLM connections
# (OOM, CUDA hang) without killing legitimately slow runs. Default 600s
# (bumped from 300s on 2026-04-28) gives headroom for slow image-gen workloads
# (FLUX Dev / 1024×1024 SDXL fine-tunes) where the LLM stays idle while
# ComfyUI runs on the same GB10 GPU. Drop to 300 if you only run fast models
# and want quicker hang-detection feedback.
OPENCLAW_LLM_IDLE_TIMEOUT_SECONDS=600

# Per-file char budget for workspace bootstrap files (patcher step 8b
# writes this into `agents.defaults.bootstrapMaxChars`). The upstream
# SDK default is 12000 — too tight for the discord-friend AGENTS.md
# which has image cheatsheet + video cheatsheet + browser cheatsheet
# + cron cheatsheet stacked together (~14k chars combined). When the
# file exceeds the per-file budget, openclaw silently TRUNCATES the
# tail in the injected context: the agent loses whatever lives at the
# bottom of AGENTS.md.
#
# Verified live 2026-05-14: video cheatsheet additions (resolution
# recipes, I2V routing examples, display_markdown paste contract) sat
# at the bottom of AGENTS.md and got cut at the 12k boundary — the
# bot defaulted to T2V on I2V intents (vision-described the image
# instead of using init_image_url), insisted "felbontás nem
# választható" when asked for HD, and skipped the URL paste.
#
# 20000 fits the current cheatsheet stack with ~5k headroom. Bump
# further if you add more cheatsheets and see the truncation warning
# return in gateway logs:
#   docker logs openclaw-gateway | grep "truncating in injected context"
OPENCLAW_BOOTSTRAP_MAX_CHARS=20000


# MCP tool-call request timeout (milliseconds). The upstream
# `@modelcontextprotocol/sdk` hardcodes a 60 s default for `client.request()`
# and OpenClaw's runtime calls `session.client.callTool({...})` without a
# per-server timeout override, so ANY tool that takes longer than 60 s
# surfaces a spurious `MCP error -32001: Request timed out` to the agent
# even when the underlying operation succeeds. This hits:
#
#   - LTX-Video cold-cache renders (~130 s on GB10 to load 30 GB checkpoint
#     + 9 GB encoder from disk; warm-cache calls are ~24-30 s and fit fine)
#   - FLUX-Krea cold-cache renders (~90 s)
#   - Any future high-resolution / long-duration video render (4 K can run
#     many minutes)
#   - python_sandbox exec calls that block on long subprocess work
#
# The `openclaw-base-ext` Dockerfile sed-patches the SDK constant to read
# this env at process start. Default 1800000 ms = 30 minutes. Bump on
# deploys that regularly render 4K video or run multi-minute tools.
# Setting absurdly high values just delays the error surface for genuinely
# hung tools — no other cost.
#
# Scope: applies to openclaw-gateway + openclaw-cli (the two services that
# make MCP tool calls). Re-apply after `docker compose build --no-cache
# openclaw-config-init` if you bump the patcher logic.
MCP_REQUEST_TIMEOUT_MS=1800000


# ----------------------------------------------------------------------------
# OpenClaw heartbeat — proactive agent check-ins
# ----------------------------------------------------------------------------

# Active hours (inclusive). Outside this window the heartbeat does not wake up
# — saves idle vLLM prefills overnight. Start > End wraps around midnight.
OPENCLAW_HEARTBEAT_ACTIVE_START=09:00
OPENCLAW_HEARTBEAT_ACTIVE_END=02:00

# IANA timezone for both heartbeat.activeHours AND dreaming.frequency.
# Examples: America/Los_Angeles, Europe/Berlin, Asia/Tokyo, UTC.
OPENCLAW_HEARTBEAT_TZ=UTC


# ----------------------------------------------------------------------------
# OpenClaw dreaming (REM-style memory consolidation)
# ----------------------------------------------------------------------------

# Default 1: nightly memory consolidation enabled (light/deep/rem phases).
# Requires an OpenClaw image >= 2026.4.15 — this is the current stable. Set to
# 0 if you're pinned to an older gateway tag (older versions reject the
# memory-core plugin schema).
OPENCLAW_ENABLE_DREAMING=1


# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------

# Docker Compose project name. Scopes docker-managed resources (default bridge,
# auto-generated volumes, etc.) to this project so multiple stacks can coexist
# on one host. Does NOT affect the container names shown in `docker ps` — those
# are controlled by CONTAINER_NAME_PREFIX below.
COMPOSE_PROJECT_NAME=dgx-openclaw

# Prefix prepended to every container name. Default empty → bare names like
# `vllm-llm`, `openclaw-gateway` in `docker ps`. Set to a prefix (e.g. `dgx-`)
# if you're running multiple stacks on one host and want namespace isolation
# (`dgx-vllm-llm`, `dgx-openclaw-gateway`, …). Does NOT affect bridge DNS
# reachability of sibling containers — those resolve by the compose service
# name (`vllm-llm`, `searxng`, `openclaw-gateway`) regardless of the
# container_name value.
CONTAINER_NAME_PREFIX=

# vLLM log verbosity (ERROR / WARNING / INFO / DEBUG).
VLLM_LOGGING_LEVEL=INFO

# Default container timezone for the OpenClaw services.
TZ=UTC

# OpenClaw gateway image ref. The compose file embeds this after the bare
# image name (`ghcr.io/openclaw/openclaw`) for all three openclaw-{config-
# init,gateway,cli} services, so the value MUST include its own qualifier:
#   - `:<tag>` — e.g. `:latest` (moving target) or `:2026.4.15`
#   - `@<digest>` — e.g. `@sha256:9d5f1dfb...` (immutable, reproducible)
#
# Docker tag grammar forbids colons inside a tag, so a bare
# `sha256:…` value produces `invalid reference format`. Use `@sha256:…`
# for digest pins.
#
# Default `:latest` pulls the newest stable gateway on every
# `docker compose pull` (convenient, implicit upgrades); pin to a digest
# for reproducible deploys that no `pull` can drift. Examples:
#
#   OPENCLAW_IMAGE_REF=:latest
#   OPENCLAW_IMAGE_REF=:2026.4.22
#   OPENCLAW_IMAGE_REF=@sha256:639fc648f1e2cb9137cd2d4513038e3b5efdebc94a6bd7fbef42c908005945f4
#
# Upgrade runbook (pull, verify, rollback) in `docs/CUSTOMIZATION.md`.
# OPENCLAW_IMAGE_REF=:latest


# ----------------------------------------------------------------------------
# TTS — Kokoro 82M (English, default) + optional F5-TTS (Hungarian, opt-in)
#
# The English TTS surface is enabled by default once OPENCLAW_TTS_ROUTER_API_KEY
# and TTS_API_TOKEN above are set (the bootstrap script generates both). English
# (Kokoro 82M, Apache 2.0) ships in this stack as the openclaw-tts-en service.
# Coexists with the Gemma 4 NVFP4 LLM on the same GB10 GPU (~500 MB - 1 GB VRAM).
#
# Default Kokoro voice the router falls back to when the request omits one.
# A-grade alternates: af_bella (US female), bf_emma (UK female), am_michael
# (US male), af_nicole (US female, headphones trait).
# TTS_EN_DEFAULT_VOICE=af_heart

# Default voice id the gateway sets on outgoing TTS requests (read by patcher
# step 11 → messages.tts.providers.openai.voiceId). Usually the same as the
# router default.
# OPENCLAW_TTS_DEFAULT_VOICE=af_heart

# Override KOKORO_DEVICE=cpu to run Kokoro without a GPU (~10× slower; useful
# on a remote-vLLM deployment where this host has no GPU).
# KOKORO_DEVICE=cuda

# Host-side bind for the EN backend (Kokoro). Default 127.0.0.1 = loopback only
# — only this host can hit it (debugging via `curl 127.0.0.1:8091/healthz`).
# The OpenClaw gateway always reaches it via bridge DNS, regardless. Set to
# 0.0.0.0 ONLY if you actively want LAN clients to reach the EN backend
# directly (the service is Bearer-token-protected via TTS_API_TOKEN, but a
# leaked token is still a leaked token).
# TTS_EN_BIND=127.0.0.1
# TTS_EN_PORT=8091

# Host-side bind for the OpenAI-compat router. Same loopback-only default. The
# OpenClaw gateway reaches the router via bridge DNS — set 0.0.0.0 only if a
# LAN client (e.g. a third-party app calling /v1/audio/speech directly) needs
# direct access. Bearer-token-protected via OPENCLAW_TTS_ROUTER_API_KEY.
# TTS_ROUTER_BIND=127.0.0.1
# TTS_ROUTER_PORT=8092

# Leading silence (ms) prepended to every TTS reply via ffmpeg adelay filter.
# F5-TTS emits audio with essentially no leading silence — the first phoneme
# starts at t=0 — which collides with Whisper's ~50-100 ms STT warm-up window
# and the first sound gets dropped (observed as "Szia" -> "Zia" in round-trip
# benchmarks). A 200-400 ms pad gives the STT room to settle. Kokoro EN is
# less affected but the pad is free (<1 ms ffmpeg overhead) and harmless.
# Set to 0 to disable entirely (brings back the onset-clip bug on HU short
# utterances — keep at 300 unless you have a specific reason).
# ROUTER_LEADING_SILENCE_MS=300


# ----------------------------------------------------------------------------
# OPTIONAL: Hungarian TTS — F5-TTS, OPT-IN, CC-BY-NC model weights
#
# Wrapper code is MIT; the bundled model weights (`sarpba/F5-TTS_V1_hun_v2`)
# are CC-BY-NC-4.0 — NON-COMMERCIAL USE ONLY. Building the openclaw-tts-f5hun
# image triggers the HF download and constitutes acceptance of the upstream
# model license. The repo ships no model weights of any kind. For commercial
# use, override F5_CHECKPOINT / F5_VOCAB inside the openclaw-tts-f5hun service
# (see openclaw-tts-f5hun/README.md).
#
# Three independent levers must align to activate the HU service — the
# bootstrap.sh prompts for opt-in and sets all three for you, or you can
# uncomment the lines below by hand:
#   1. F5HUN_API_TOKEN — Bearer token for the HU /v1/audio/speech endpoint
#   2. F5HUN_URL — router → HU backend address (bridge DNS works as-is)
#   3. COMPOSE_PROFILES=hu — activates the openclaw-tts-f5hun service block
#
# Once active, the router exposes the HU voice ids (default_hu, hu_diana) and
# the diacritic-based autodetect: input containing áéíóöőúüű is silently
# re-routed to the HU backend even when the agent asks for an English default
# voice — keeps Hungarian phonetics from being mangled by the English G2P.
# ----------------------------------------------------------------------------
# F5HUN_API_TOKEN=CHANGE_ME_run_openssl_rand_base64_64
# F5HUN_URL=http://openclaw-tts-f5hun:8080/v1/audio/speech
# COMPOSE_PROFILES=hu

# Default voice the HU backend uses when a request omits one. The bundled
# `default_hu` is built from a public-domain LibriVox recording (Diana
# Majlinger reading from Géza Gárdonyi's "Egri csillagok" — a 19th-century
# Hungarian historical novel). Drop your own <name>.wav + <name>.txt into the
# tts-f5hun-voices Docker volume to add cloned voices.
# F5HUN_DEFAULT_VOICE=default_hu

# Voice the router re-routes to when HU autodetect fires. Only effective when
# all three F5HUN_* opt-in vars above are set.
# TTS_HU_AUTOROUTE_VOICE=default_hu

# Override F5HUN_DEVICE=cpu to run F5-TTS without a GPU (much slower; useful
# on a remote-vLLM deployment where this host has no GPU).
# F5HUN_DEVICE=cuda

# Host-side bind for the HU backend (F5-TTS). Same loopback-only default as
# the EN service. Bearer-token-protected via F5HUN_API_TOKEN. The router
# reaches this via bridge DNS regardless of the binding.
# TTS_F5HUN_BIND=127.0.0.1
# TTS_F5HUN_PORT=8090


# ----------------------------------------------------------------------------
# STT — faster-whisper large-v3 (English + Hungarian, autodetect)
#
# The STT surface is enabled by default once STT_API_TOKEN above is set (the
# bootstrap script generates it). Model: MIT-licensed Whisper large-v3 served
# by a ~150 LOC FastAPI wrapper around faster-whisper, built from
# ./openclaw-stt-whisper/server/ on a CUDA 13 base (see that folder's
# README.md for why we self-build instead of using the speaches upstream
# image — in short: Blackwell sm_120 compute-kernel compat). Whisper
# autodetects the input language per request, so no bilingual router is
# needed. FLEURS Hungarian WER 14.1%.
#
# OpenClaw consumption: patcher step 14 writes an entry into
# tools.media.audio.models[] pointing here. Consumed by voice-note upload
# (attach a wav/mp3 in the Control UI chat composer), Discord voice channels,
# the VoiceCall CLI, and the Talk / Voicewake node pipelines. The Control UI
# realtime mic button is a separate path — it uses the browser's native Web
# Speech API, which does NOT route through this service.
#
# Budget: ~3 GB VRAM at float16; ~12 GB headroom remains on a 128 GB GB10 with
# LLM_GPU_MEM_UTIL=0.68 and the Kokoro TTS running.
# ----------------------------------------------------------------------------

# HuggingFace model id the backend loads on first request.
# Default (active when this line stays commented): Trendency/whisper-large-v3-hu
#   Hungarian Whisper fine-tune, Apache-2.0, ~11% CV WER. Validated on
#   GB10 against vanilla large-v3:
#     - Hungarian: ~7-8 fewer mis-hearings per chapter (János Vitéz
#       LibriVox); survives telephone-bandpass + pink noise degradation
#       with minimal extra errors.
#     - English: identical output on the JFK 11-sec reference clip —
#       no degradation observed on bilingual workloads at smoke scale.
#   First-boot HF download + CT2 float16 conversion is ~3 min (cached in
#   the stt-whisper-hf-cache volume thereafter).
#
# Override with the pure multilingual baseline if your workload is
# English-heavy and you want maximum-safety on unseen English:
# STT_WHISPER_MODEL=Systran/faster-whisper-large-v3
#
# Any HuggingFace Whisper repo id works — the wrapper auto-detects
# non-CT2 repos and converts them to CT2 float16 on first boot.
# Example (community fine-tune with a cleaner train/eval split):
# STT_WHISPER_MODEL=Trendency/whisper-large-v3-hu
#
# Swap is reversible. Converted CT2 artefacts coexist in the HF volume,
# so flipping back and forth between tested models is instant (no
# re-download, no re-convert).

# Inference precision. CTranslate2 on Blackwell (sm_120) may reject some
# low-precision kernel classes even on a CUDA 13 build — if the first
# transcribe raises a `ValueError: target device or backend do not support
# efficient X computation`, fall through the ladder in this order:
#   1. float16 (default, ~3 GB VRAM, full quality).
#   2. bfloat16 (same speed class, numerically more robust on newer HW).
#   3. int8_float16 (~1.5 GB VRAM, 5-10% WER cost).
#   4. int8_bfloat16 (same VRAM as above, alternate kernel class).
#   5. int8 (slow on GPU; reliable fallback).
#   6. float32 (~6 GB VRAM, slowest but no quantization — lossless baseline).
# STT_WHISPER_COMPUTE_TYPE=float16

# Device to run inference on. `cuda` (default) for GPU; `cpu` on a GPU-less
# host (e.g. a remote-vLLM deployment — ~50× slower, realistic only for short
# voice notes).
# STT_WHISPER_DEVICE=cuda

# Turbo alternate (8× faster, ~1.6 GB VRAM, ~equal EN WER). Hungarian WER is
# NOT independently published for the turbo variant — run your own HU samples
# through both and compare before switching in production use:
# STT_WHISPER_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Host-side bind for the STT backend. Default 127.0.0.1 = loopback only (LAN
# cannot reach it — debug via `curl 127.0.0.1:8093/health`). The OpenClaw
# gateway always reaches it via bridge DNS, regardless. Set to 0.0.0.0 ONLY
# if you actively want LAN clients to POST /v1/audio/transcriptions directly
# (still Bearer-protected via STT_API_TOKEN, but a leaked token is a leaked
# token — keep the loopback default unless you have a reason).
# STT_WHISPER_BIND=127.0.0.1
# STT_WHISPER_PORT=8093

# Gateway wiring (consumed by openclaw-config-init step 14):
# OpenClaw convention is trailing-slash on baseUrl — the patcher appends one
# if missing, so either form works.
# OPENCLAW_STT_BASE_URL=http://openclaw-stt-whisper:8080/v1
# OPENCLAW_STT_MODEL=Systran/faster-whisper-large-v3
# OPENCLAW_STT_LANGUAGE=           # empty = Whisper autodetects the language


# ----------------------------------------------------------------------------
# Optional: remote vLLM / cloud LLM backend
#
# By default the gateway, config patcher, and CLI all reach the in-compose
# vllm-llm and vllm-embedding services by their bridge-DNS names. If you'd
# rather host the heavy LLM (and/or embedding) on a different machine — a
# remote DGX over LAN, a cloud OpenAI-compatible endpoint (Bedrock proxy,
# OpenRouter, vLLM-on-RunPod, …) — uncomment the three vars below and add
# `profiles: ["never"]` to vllm-llm + vllm-embedding in docker-compose.yml so
# they don't try to spin up locally.
#
# All three must be reachable from inside the openclaw-gateway container.
# The remote vLLM API key still uses VLLM_API_KEY above.
#
# Full walkthrough: docs/CUSTOMIZATION.md → "Run with a remote vLLM backend".
# ----------------------------------------------------------------------------
# OPENAI_BASE_URL=https://your-remote-vllm.example.com/v1
# LLM_BASE_URL=https://your-remote-vllm.example.com/v1/
# EMBED_BASE_URL=https://your-remote-embed.example.com/v1/


# ----------------------------------------------------------------------------
# Optional: Discord agent (OPT-IN — text channels by default; voice optional)
#
# Lets you bind an OpenClaw-controlled bot to a Discord guild. Two scopes
# share the same wiring (token + isolated agent + channel binding):
#   - Text-channel agent: read/write messages, edit/delete own messages, add
#     reactions, share images (via comfyui_image), web-search w/ citations,
#     per-user memory. See docs/CUSTOMIZATION.md → "Discord agent" runbook.
#   - Voice-channel agent: STT (Whisper) + TTS (Kokoro/F5-TTS) round-trip.
#     Adds Connect/Speak permissions + DISCORD_AUTOJOIN_* below. See
#     docs/CUSTOMIZATION.md → "Voice-controlled agent over Discord".
#
# ISOLATION POSTURE (important): the Discord agent runs in a SEPARATE
# workspace from your main agent, so anyone with access to the bound channel
# cannot extract memory notes, chat history, or personal files from your
# primary workspace. Enforced at `openclaw agents add` time via a dedicated
# workspace path + a `cautious` exec-policy preset.
#
# Three independent levers must align to bring this online:
#   1. DISCORD_BOT_TOKEN — your bot's secret, from the Discord Developer
#      Portal (Applications → your app → Bot → Reset Token). Treat like a
#      password. Leaking it lets anyone control your bot.
#   2. A dedicated isolated agent — `openclaw agents add ${DISCORD_AGENT_NAME}
#      --workspace ${DISCORD_WORKSPACE_DIR} --bind discord`.
#   3. Channel → agent binding — passed via `--bind discord` above; the
#      gateway routes inbound Discord traffic to this agent.
#
# Never made a Discord bot before? Full portal walkthrough (permissions,
# intents, server invite) in docs/discord-bot-setup.md.
# ----------------------------------------------------------------------------

# Bot token from https://discord.com/developers/applications — paste the
# "Reset Token" output here. Empty = Discord integration disabled. The
# patcher will not create or modify `channels.discord.*` while this is empty.
DISCORD_BOT_TOKEN=

# Name of the isolated agent that handles Discord traffic. The setup runbook
# creates this agent via `openclaw agents add ${DISCORD_AGENT_NAME}
# --workspace ${DISCORD_WORKSPACE_DIR}`. Keep it distinct from "main" so that
# exec-policy, memory sources, and tool scopes are separately tunable.
# Default `discord-friend` matches the text-channel runbook; rename to
# `discord-voice` (or anything else) if you start from the voice runbook.
DISCORD_AGENT_NAME=discord-friend

# Host path for the Discord agent's ISOLATED workspace. Must NOT overlap
# with OPENCLAW_WORKSPACE_DIR — that is where your personal memory lives.
# The bootstrap script does not create this directory automatically; the
# runbook includes the mkdir step.
DISCORD_WORKSPACE_DIR=/opt/openclaw/workspace-discord

# Optional (voice-channel scope only): auto-join a specific Discord guild
# + voice channel at gateway startup. Both must be numeric Discord snowflake
# IDs (enable Developer Mode in Discord → right-click guild/channel → "Copy
# ID"). Leave empty for manual-join-on-demand via the `/vc join` slash
# command. Irrelevant for the text-channel agent.
# DISCORD_AUTOJOIN_GUILD_ID=
# DISCORD_AUTOJOIN_VOICE_CHANNEL_ID=

# OpenClaw's Discord plugin auto-fires an "I see your message" emoji ack
# (👀 / 🤔 / 👍 / 🔥 lifecycle) on inbound mentions. Upstream issue #46024
# documents a stale-queue replay bug: after a heartbeat / cron cycle the
# delivery queue resends buffered ack-reaction events, so the bot rapidly
# cycles through 3-5 emojis on the user's message without the agent having
# any tool-call awareness of doing it. Symptom: bot reacts with rotating
# emojis on every mention; not a Gemma reasoning loop. Patcher step 20
# defends against this by setting `channels.discord.ackReactionScope = "off"`
# when the channel is configured. Default `off`. Override with
# `group-mentions` / `direct` / `all` if you actually want the lifecycle
# feedback (and accept the cycling); `none` is also a valid disable.
# Enum: off | none | group-mentions | group-all | direct | all
# OPENCLAW_DISCORD_ACK_REACTION_SCOPE=off

# Discord agent-facing reaction tool (`discord:add_reaction`). Default `true`
# (enabled) because this stack ships a custom vllm-llm image (./vllm-llm/
# Dockerfile + patch_parser.py) with a 1-line patch to the Gemma4 tool-call
# parser regex — upstream `[\w\-\.]+` rejects colon namespaces, the patched
# version `[\w\-\.:]+` accepts them. Without the patch (e.g. you commented
# out the build: directive on vllm-llm and pulled an unpatched upstream
# image), Gemma 4 NVFP4 calls `discord:add_reaction` correctly but vLLM's
# parser drops the call and the literal `<|tool_call>...<tool_call|>` envelope
# leaks into Discord chat as garbage text — set this to `false` in that case.
# Also set false to strip reaction permissions for guild-rule reasons.
# OPENCLAW_DISCORD_ACTIONS_REACTIONS=true

# Progressive Discord message delivery — `channels.discord.streaming`. Upstream
# default `"off"` posts replies atomically: with Gemma 4 NVFP4 at ~6 tok/s, a
# 500-token reply produces ~80 seconds of dead silence in the channel before
# anything appears, and users perceive the bot as frozen. The patcher (step 24)
# writes `"partial"` by default — a single placeholder message gets edit-in-place
# as tokens arrive. Discord rate limit is 5 edits / 5s per channel; at 6 tok/s
# with the docs-default draftChunk.minChars=200 (~33 tokens), the cadence is
# ~5.5s/edit — well within the limit on a single dedicated bot account.
# Modes:
#   off       — atomic delivery (upstream default; no progressive UX).
#   partial   — single preview message edit-in-place as tokens arrive (recommended).
#   block     — paragraph-sized chunks posted as separate messages.
#   progress  — Discord-side alias of `partial`.
# Caveats: media / error / explicit-reply finals cancel the pending preview
# edit and the final arrives atomically (correct, not regression). Streaming
# is text-only; image/file attachments use the normal atomic path. If MULTIPLE
# bots or gateways share a single Discord application token, edit-rate
# collisions become likely — set `off` in that case. The patcher only writes
# the field if `channels.discord` is configured AND the operator hasn't set
# `streaming` themselves; explicit operator values are preserved. Set this var
# to an empty string to skip patcher step 24 entirely.
# OPENCLAW_DISCORD_STREAMING=partial

# Fine-tune the draft chunk that the streaming pipeline emits per edit. All
# three knobs respect user-managed protection (only write when the field is
# undefined in openclaw.json). Each is independently optional — leave any
# unset to inherit the OpenClaw docs default (200 / 800 / "paragraph").
#
# Use case: paragraph-grain edits (the default) feel chunky for short
# interactive replies. Setting `BREAK_PREFERENCE=newline` + `MIN_CHARS=100`
# shifts to ~2-3s line-grain edits — visibly closer to typing UX. Below
# ~80 chars (~13 tokens at 6 tok/s ≈ 2s/edit cadence) you start brushing
# Discord's 5edits/5s rate limit on a single dedicated bot account.
#
# `BREAK_PREFERENCE` enum is `paragraph` (default), `newline`, `sentence`.
# Confirmed via runtime validator error on openclaw 2026.4.22 (the upstream
# docs only list "paragraph"). The most common wrong guess is `line` — the
# patcher rejects unknown values with a warning to avoid crashing the
# gateway with an invalid config.
# OPENCLAW_DISCORD_DRAFTCHUNK_MIN_CHARS=100
# OPENCLAW_DISCORD_DRAFTCHUNK_MAX_CHARS=500
# OPENCLAW_DISCORD_DRAFTCHUNK_BREAK_PREFERENCE=newline

# Tool-progress lines in the streaming preview (`Working...\n- tool: <name>`).
# Default upstream `true` — useful to see what the agent is doing mid-stream
# (web_search, comfyui_image__generate, browser.act, …). Known cosmetic bug
# on Discord 2026.4.22: tool names with double-underscore separators
# (`comfyui_image__generate`) get mangled by Discord's italic markdown parser
# — `_image_` becomes italic mid-name and the line looks broken. The only
# upstream-supported knob is on/off; there is no documented flag to
# escape the tool name or wrap it in a code block. Set this var to `false`
# if the rendering bothers you more than the loss of mid-stream visibility.
# See docs/upstream-feedback/discord-toolprogress-rendering.md for the
# tracked feature request.
# OPENCLAW_DISCORD_STREAMING_PREVIEW_TOOL_PROGRESS=true

# Discord-routed agent tool capability. Both knobs target the agent that
# `openclaw agents bindings` shows on the discord channel route (typically
# `discord-friend` after `openclaw agents add` during onboarding).
#
# Tool profile (patcher step 25). Default `full` — same effective surface
# as the main agent: cron, browser, image_generate, web_search, memory,
# python_sandbox, tts, canvas, messaging. The OpenClaw default for
# non-main agents is `coding`, which excludes browser, tts, and canvas.
# Symptoms of leaving the default:
#   - "screenshot startlap.hu" → "Sorry, I can't navigate the browser."
#   - voice attach fails silently (the `[[tts:speak]]` directive is parsed
#     but the underlying tool isn't in the catalog, so no audio attaches).
#   - canvas-embed shortcodes from comfyui_image generations don't render
#     inline (no `canvas` tool to mint same-origin URLs).
# Tighten to `coding` or `messaging` if you have a security reason;
# `minimal` disables almost everything. The step skips when the value is
# empty or `tools.profile` is already set in openclaw.json.
# Enum: minimal | coding | messaging | full
# OPENCLAW_DISCORD_AGENT_TOOLS_PROFILE=full

# tools.alsoAllow boost (patcher step 22). Comma-separated list of tools
# or groups to ADD on top of the profile. Default
# `group:messaging,browser,tts,canvas` — group:messaging surfaces the
# `message` tool (used for action: send / edit / react); browser, tts, and
# canvas are belt-and-braces redundancy in case an operator later switches
# the profile to something stricter. The step preserves anything you
# already added to alsoAllow in openclaw.json (set-union). Empty string
# disables the step entirely.
# OPENCLAW_DISCORD_AGENT_ALSO_ALLOW=group:messaging,browser,tts,canvas

# Slash-command authorization mode (patcher step 28). Defends against
# upstream issue #19310: native slash commands (`/discord input:`,
# `/talkvoice input:`, `/activation mode:`) work in DM via dmPolicy=
# "pairing" but get silently blocked in guild channels with an ephemeral
# "You are not authorized to use this command" because the dual perm
# check (global allowFrom + per-guild users array) is empty by default.
# The slash UX is materially better than @mention text — Discord renders
# an immediate ack-dot "thinking…" indicator, no dead-air gap.
# Modes:
#   open        — allowFrom=["*"] + dmPolicy="open" + groupPolicy="open"
#                 (default). Every guild member can invoke slash commands.
#                 Recommended for single-operator homelab deploys where
#                 the bot lives in your own guild(s).
#   allowlist   — skip the step entirely; preserve upstream defaults
#                 (dmPolicy="pairing", groupPolicy="allowlist"). Use on
#                 shared bots, multi-tenant guilds, or public servers.
#   owner-only  — lock to OPENCLAW_DISCORD_OWNER_IDS (comma-separated
#                 17-20-digit Discord snowflakes). Writes allowFrom +
#                 dmPolicy="allowlist" + groupPolicy="allowlist".
# User-managed protection: each field only written when undefined in
# openclaw.json. If you hand-set allowFrom / dmPolicy / groupPolicy, those
# wins.
# OPENCLAW_DISCORD_AUTHZ=open
# OPENCLAW_DISCORD_OWNER_IDS=        # only used when AUTHZ=owner-only

# Discord voice subsystem (patcher step 29). Registers /vc join|leave|status
# native slash commands and opens the voice-channel surface for the bot.
# Default `stt-tts` — pairs with this stack's self-hosted faster-whisper STT
# (port 8093) + Kokoro/F5-TTS via the TTS router (port 8090), fully offline.
# Modes:
#   stt-tts      — batch STT + TTS pipeline (recommended on this stack).
#   agent-proxy  — realtime voice frontend; delegates to agent via
#                  openclaw_agent_consult. Requires a realtime-capable
#                  provider (OpenAI Realtime, etc.) — NOT wired on this
#                  stack out of the box.
#   bidi         — realtime model converses directly with tool exposure.
#                  Same realtime-provider requirement as agent-proxy.
#   off          — skip the substep, leave the voice surface gated off.
# Discord bot also needs Connect + Speak permissions in the target voice
# channel; re-invite via the OAuth URL Generator if they're missing.
# OPENCLAW_DISCORD_VOICE=stt-tts

# Discord thread bindings (patcher step 29). Registers /focus, /unfocus,
# /agents, /session idle, /session max-age — lets a Discord thread bind
# to a specific subagent/session so follow-ups stay on the same conv rail.
# Opt-in per-thread via /focus, not automatic. Default `on` on this stack
# because the workflow is genuinely useful for any multi-session homelab.
# Set `off` if you want a simpler bot with no thread machinery.
# OPENCLAW_DISCORD_THREAD_BINDINGS=on

# Discord guild mention gate (patcher step 30). Writes the wildcard
# `channels.discord.guilds["*"].requireMention` so the same gate posture
# applies to every guild the bot joins, with NO operator guild IDs baked
# into the public repo. The bundled guild-entry resolver tries id-match
# → slug-match → `entries["*"]` fallback, so per-guild overrides set via
# `openclaw config set channels.discord.guilds.<id>.requireMention …`
# still win over this wildcard default.
#
# Values:
#   off (DEFAULT) — gate open in every guild: `guilds["*"].requireMention
#                   = false`. Bot sees every guild message and the LLM
#                   decides per-message whether to reply (using the
#                   silent token when not addressed). Single-operator
#                   homelab posture; matches the rest of this stack's
#                   wide-open defaults (OPENCLAW_DISCORD_AUTHZ=open,
#                   voice + threadBindings on, slash UX everywhere).
#   on            — skip the step. Preserves upstream's mention-required
#                   gate (bot only sees messages that @mention it or
#                   reply to its own messages). Pick this for shared,
#                   multi-tenant, or public deploys.
#
# Note on `/activation`: the slash is an LLM-behavior hint, not a gate
# toggle. It writes `sessionEntry.groupActivation` which the agent's
# system-intro consumes (always = "use silent token to stay quiet";
# mention = "you're invoked only when mentioned"). The gate is whatever
# this env knob produced; the slash tells the LLM how to behave inside
# that gate. See CLAUDE.md "Discord mention gate vs /activation slash"
# for the full breakdown.
# OPENCLAW_DISCORD_REQUIRE_MENTION=off


# ----------------------------------------------------------------------------
# Browser automation — Playwright Chromium via Chrome DevTools Protocol
# (OPT-IN, profile=browser)
#
# OpenClaw's built-in `browser` tool attaches to a self-hosted Chromium
# cluster running in the openclaw-browser container. Each onboarded
# credential gets its own warm Chromium with persistent user-data-dir
# (cookies survive restart for ~14d GitHub / ~30d Notion / etc.). 1x manual
# OAuth onboarding via headful Chromium + noVNC — see
# `./bootstrap-browser-login.sh <profile-name>`.
#
# Three independent levers must align to bring this online (mirrors the
# Hungarian-TTS opt-in pattern):
#   1. BROWSER_API_TOKEN — generated by bootstrap.sh on explicit opt-in.
#   2. The `browser` Compose profile must be active. Either set
#      `COMPOSE_PROFILES=browser` below (or `hu,browser` if you also opted
#      into HU TTS), or pass `--profile browser` on the docker compose
#      command line.
#   3. At least one onboarded credential — `./bootstrap-browser-login.sh`.
#      For the anonymous default profile, no onboarding step is needed —
#      it boots automatically once the service is up.
#
# Limitations to set expectations:
#   - Passkeys (FIDO2/WebAuthn) DO NOT work over the noVNC bridge —
#     W3C origin-bound spec. Use password+TOTP / SMS OTP. For services
#     that offer long-lived API tokens (GitHub PATs, Notion integration
#     tokens, Linear API keys), use those instead — store the token in
#     a service-specific env var or `.env` line and reach the API
#     directly without the browser at all.
#   - Vanilla Playwright Chromium ships `navigator.webdriver=true`. Fine
#     on user-owned authenticated accounts (GitHub, Notion, Patreon,
#     MediaWiki); will be detected on Cloudflare/DataDome/PerimeterX-
#     fronted hostile sites. No stealth shipped by default. Patchright
#     is documented as a Phase 2 swap if needed.
# ----------------------------------------------------------------------------

# Comma-separated list of named profiles. Maintained by
# ./bootstrap-browser-login.sh — manual edits work but DO NOT reorder
# existing names: each name's port is positional (default=9222, then
# 9223, 9224, …), and reordering would shuffle every cdpUrl in
# openclaw.json on the next patcher run.
# BROWSER_PROFILE_NAMES=

# Host-side bind for the management API (port 9220) AND for the Chromium
# remote-debugging ports (9222-9241). Default 127.0.0.1 = loopback only.
# OpenClaw's gateway always reaches openclaw-browser via bridge DNS at
# `openclaw-browser:9222-9241`, so the host bind is operator-debug only.
# Set BROWSER_BIND=0.0.0.0 ONLY if you want a LAN client to attach
# directly — and only with a header-auth reverse proxy in front, since
# the query-string token is weaker than a bearer header.
# BROWSER_BIND=127.0.0.1
# BROWSER_API_PORT=9220

# Host-side bind for the noVNC port (5901). Same loopback-only default.
# noVNC bridge is now ALWAYS-ON: Xvfb + x11vnc + websockify start with the
# container so you can attach any time the operator wants to peek at a
# headful Chromium. Outside an active login-helper window the screen is
# blank (no headful Chromium attached to Xvfb). Pop a profile into headful
# mode via ./bootstrap-browser-login.sh <name> to see the agent's view.
# BROWSER_VNC_BIND=127.0.0.1
# BROWSER_VNC_PORT=5901

# Persistent VNC password used by the noVNC bridge. bootstrap.sh generates
# this on first run and rotate-secrets.sh --all rotates it. The value is
# embedded in the noVNC URL as ?password=<...> for browser auto-fill.
#
# Practical note on entropy: the legacy VNC RFB Type-2 handshake truncates
# the password to 8 chars at the wire layer, so anything beyond ~48 bits of
# effective entropy is theatre. We still generate 32 random chars so the
# value looks like the other secrets and rotation isn't a corner case;
# real defense in depth is BROWSER_VNC_BIND=127.0.0.1 + the LAN being
# trusted. Don't expose the noVNC port to the public internet.
BROWSER_VNC_PASSWORD=CHANGE_ME_VNC_PASSWORD

# Viewport size for both Xvfb (headful render screen) and Chromium's
# --window-size launch flag. Default 1920x1080 — Full HD desktop, matches
# what most real users report. The two values are kept in lock-step so
# iframe-rect math, full-page screenshots, and pixel-coord automation all
# agree on the same coordinate space; they must match. Lowering to e.g.
# 1280x720 saves a bit of RAM but cramps anti-bot CAPTCHA iframes that
# render at a fixed size (520x570 hCaptcha challenge).
# BROWSER_VIEWPORT_WIDTH=1920
# BROWSER_VIEWPORT_HEIGHT=1080

# Per-host rate limiter for application-layer browse calls (the
# blocklist + retry safety net). 0.5 rps / 5 burst is a respectful
# default for the public web; bump to 5 rps for your own MediaWiki /
# Notion / GitHub if you find the agent queueing too much.
# BROWSER_RATE_LIMIT_RPS=0.5
# BROWSER_RATE_LIMIT_BURST=5

# Soft cap on warm profiles (matches the published port range
# 9222-9241). Bumping this requires expanding the port range in
# docker-compose.yml as well.
# BROWSER_MAX_PROFILES=20

# Default navigation timeout (ms).
# BROWSER_DEFAULT_TIMEOUT_MS=30000

# Override the docker-compose bridge DNS host the patcher uses when
# building cdpUrls. Useful only if you're routing OpenClaw at the
# browser service through a non-default network alias (rare).
# BROWSER_CDP_HOST=http://openclaw-browser
# BROWSER_PORT_BASE=9222


# ----------------------------------------------------------------------------
# Python code-execution sandbox (OPT-IN, profile=python)
#
# Self-hosted Python execution backend that the OpenClaw agent reaches over
# MCP (mcp.servers.python_sandbox, transport: streamable-http). Persistent
# ipykernel per session_id — same id across calls keeps state, so a multi-
# step analysis (load CSV → reduce → plot → export) doesn't have to re-load
# the dataset every tool call. Data-science stack baked in (pandas, numpy,
# matplotlib Agg backend, scikit-learn, scipy).
#
# Why this and not OpenClaw's native code_execution tool: that one routes
# to xAI's Responses API (cloud, paid). This stack is self-hosted by
# design. Why not agents.defaults.sandbox + the exec tool: that controls
# shell tools gateway-wide; flipping it to Python-as-default would shift
# behavior for every other tool too. The MCP path is Python-specific,
# scoped, and opt-in.
#
# Three independent levers (mirrors the HU-TTS / browser opt-in pattern):
#   1. PYTHON_SANDBOX_API_TOKEN — generated by bootstrap.sh on opt-in.
#   2. The `python` Compose profile must be active. Either set
#      `COMPOSE_PROFILES=python` below (or `python,browser` etc.) or
#      pass `--profile python` on the docker compose command line.
#   3. Patcher step 18 wires mcp.servers.python_sandbox iff #1 is set;
#      empty token cleanly opts out and removes any prior wiring.
#
# Threat model: trusted-prompt only. Container namespaces + non-root user
# protect the host filesystem; Python introspection or a kernel-exploit
# chain could in principle escape the container. We do NOT ship gVisor /
# firecracker. If you're running this on a multi-tenant box, that's the
# upgrade path.
# ----------------------------------------------------------------------------

# Bearer token for the MCP endpoint. bootstrap.sh prompts for opt-in and
# fills this with `openssl rand -base64 48`. Empty value = service stays
# parked AND patcher step 18 cleans the entry out of openclaw.json. Use
# rotate-secrets.sh to rotate (the key auto-includes in `--all` once set).
PYTHON_SANDBOX_API_TOKEN=

# Host-side bind for the MCP endpoint. Default 127.0.0.1 = loopback-only,
# matches the TTS / STT / browser security posture. The OpenClaw gateway
# always reaches the sandbox via bridge DNS at openclaw-python-sandbox:8094,
# so the host bind is operator-debug only. Set 0.0.0.0 if you want LAN
# clients to reach the MCP endpoint directly — and only behind a
# header-auth reverse proxy.
# PYTHON_SANDBOX_BIND=127.0.0.1
# PYTHON_SANDBOX_PORT=8094

# Per-execution wall-clock cap (seconds). Long analyses can bump this; the
# kernel is interrupted (not killed) on timeout, so the next call against
# the same session_id keeps working with the prior state intact.
# PYTHON_SANDBOX_KERNEL_TIMEOUT_S=30

# Truncation cap on (stdout + stderr + plot bytes) returned per call. 10 MB
# default is generous for typical tool-call payloads — if you regularly
# return large matplotlib figures or full datasets, bump this; if you
# never expect plots, lower it to throttle agent context bloat.
# PYTHON_SANDBOX_MAX_OUTPUT_BYTES=10485760

# Idle kernel reaper. Sessions not used for IDLE_TTL_S get shut down on a
# REAP_INTERVAL_S sweep. Trades resident memory for warm-cache convenience;
# a reaped session loses its variables and the next call starts fresh.
# PYTHON_SANDBOX_IDLE_TTL_S=1800
# PYTHON_SANDBOX_REAP_INTERVAL_S=300

# Resource caps — hard limits enforced by the docker engine.
# Memory: a kernel that goes over gets OOM-killed; the next call against
# that session transparently starts a fresh kernel. CPU: soft cap, the
# kernel is throttled rather than killed if it tries to use more.
# PYTHON_SANDBOX_MEMORY_MB=8192
# PYTHON_SANDBOX_CPUS=4

# DOCUMENTED PLACEHOLDER — not enforced in v0.8.0. Future v0.8.x patch will
# wire an `internal: true` docker network for hard egress isolation. Today,
# egress is implicitly limited by the container image's lack of network-
# using libraries (no curl/wget/requests-by-default at the agent layer)
# plus the kernel's lack of root for raw sockets. If you genuinely need to
# block outbound HTTP, attach the container to a `--internal` network
# manually.
# PYTHON_SANDBOX_NETWORK=none

# DOCUMENTED PLACEHOLDER — GPU access opt-in. Today the image is CPU-only
# (data-science workloads — pandas, plotting, light scikit-learn). To
# enable CUDA Python (PyTorch, CuPy), add `--gpus all` to the service
# block and rebuild the image with `requirements-gpu.txt`. Tracked as a
# follow-up; not wired in v0.8.0.
# PYTHON_SANDBOX_GPU=0


# ----------------------------------------------------------------------------
# Image-generation MCP bridge (OPT-IN, profile=image-gen, separate compose)
#
# Thin Python service that lets the OpenClaw agent drive image generation
# on YOUR existing ComfyUI install. The bridge speaks MCP (mcp.servers.
# comfyui_image, transport: streamable-http), translates tool calls into
# ComfyUI workflow submissions, polls for completion, and returns base64-
# encoded PNGs. The bridge does NOT run a ComfyUI itself — it expects one
# already running on the host (same box or LAN-reachable).
#
# This opt-in lives in a SEPARATE compose file
# (openclaw-image-comfyui/docker-compose.yml). The 'image-gen' profile flag
# is advisory; you bring the bridge up explicitly:
#
#   docker compose -f openclaw-image-comfyui/docker-compose.yml \
#                  --profile image-gen up -d --build
#
# Three independent levers (mirrors the python-sandbox / HU-TTS pattern):
#   1. IMAGE_GEN_API_TOKEN — bootstrap.sh prompt 3e generates one on opt-in.
#   2. The bridge container running (separate `docker compose -f ...` cmd).
#   3. Patcher step 19 wires mcp.servers.comfyui_image iff #1 is set;
#      empty token cleanly opts out and removes any prior wiring.
#
# The bridge is model-agnostic: this repo ships NO model weights. Drop your
# checkpoints (FLUX, SDXL fine-tunes, Pony XL, Illustrious, RealVisXL, etc.)
# into ComfyUI's basedir/models/checkpoints/ and reference them either
# per-call (`checkpoint=...`) or by editing a workflow JSON template under
# openclaw-image-comfyui/server/workflows/. Model licensing is your
# responsibility — same posture as F5-TTS HU.
# ----------------------------------------------------------------------------

# Bearer token for the bridge's MCP endpoint. bootstrap.sh prompts for
# opt-in and fills this with `openssl rand -base64 48`. Empty value = the
# bridge service refuses to start (auth-required) AND patcher step 19
# removes the entry from openclaw.json. Use rotate-secrets.sh to rotate
# (auto-included in `--all` only once set).
IMAGE_GEN_API_TOKEN=

# URL the bridge uses to reach YOUR ComfyUI install. Default targets the
# host gateway on port 13036, matching the most common single-box layout
# (your ComfyUI compose publishes 13036:8188 on the host loopback). Change
# this if your ComfyUI runs on a different port, or on a LAN box (e.g.
# `http://192.168.1.50:13036`). The bridge sets `extra_hosts:
# host.docker.internal:host-gateway` so the default works on Linux without
# extra plumbing.
# COMFYUI_URL=http://host.docker.internal:13036

# Browser-reachable URL the bridge embeds into the `display_markdown` field
# of the generate response. The agent pastes this markdown into its reply,
# and the OpenClaw chat surface renders the image from that URL.
#
# IMPORTANT: protocol must match your chat UI's protocol. If your chat is
# served over HTTPS (Cloudflare tunnel, reverse-proxy domain, etc.) and
# this is HTTP, the browser silently drops the <img> request as "mixed
# content" — the markdown shows up as text but the picture never loads.
#
# Three common setups, in order of preference:
#
# 1) HTTPS reverse-proxy with HTTP Basic auth (recommended for tunneled
#    chat UIs). Set up Nginx Proxy Manager or a Cloudflare-tunneled
#    subdomain in front of your ComfyUI install (e.g. comfy.your.tld
#    or vision.your.tld) and point this var at the HTTPS URL. Browsers
#    cache the Basic auth credentials per origin — log in once via the
#    browser auth dialog, every subsequent <img> request to that origin
#    sends the cached header automatically.
#      COMFYUI_EXTERNAL_URL=https://vision.example.com
#
# 2) HTTP LAN IP (works only when the chat UI is served over HTTP on the
#    same LAN; HTTPS tunnels will block it as mixed content):
#      COMFYUI_EXTERNAL_URL=http://192.168.x.x:13036
#
# 3) Default (COMFYUI_URL fallback) — host.docker.internal works ONLY
#    inside the docker bridge, NOT from the operator's browser. Leave
#    blank only if you don't need chat-side image rendering at all.
# COMFYUI_EXTERNAL_URL=

# Optional: token-protected proxy mode. When set, the bridge appends
# `?token=<value>` to every URL it embeds in `display_markdown`. Pair with
# an NGINX `if ($arg_token != "...")` validation block on your reverse-proxy
# host (vision.example.com etc.) and you can DROP the HTTP Basic auth on
# that host. The URL-param form survives both direct navigation AND
# cross-origin <img> tag fetches (Basic auth headers don't), so future
# chat-render fixes can take advantage. Set this to a long random string;
# the same value goes into the NGINX `$required_token` variable.
# Generate one with: openssl rand -base64 48 | tr -d '\n'
# See openclaw-image-comfyui/README.md for the exact NGINX recipe.
# COMFYUI_VIEW_TOKEN=

# Host-side bind for the bridge's MCP endpoint. Default 127.0.0.1 =
# loopback-only, matches the TTS / STT / browser / sandbox posture. The
# OpenClaw gateway reaches the bridge via bridge DNS at
# openclaw-image-comfyui:9095, so the host bind is operator-debug only.
# Set 0.0.0.0 only if you want LAN clients to reach the MCP endpoint
# directly — and only behind a header-auth reverse proxy. Required also
# when an external reverse-proxy (NPM container, in a separate compose
# project) needs to hit /auth-validate for `auth_request` chat-image
# token validation; the bridge's MCP endpoint is still Bearer-protected,
# /auth-validate uses constant-time compare against COMFYUI_VIEW_TOKEN.
# IMAGE_GEN_BIND=127.0.0.1
# IMAGE_GEN_PORT=9095

# Per-render wall-clock cap (seconds). 10 minutes is generous for SDXL at
# 25 steps; FLUX Schnell finishes in ~3-8s typically. The bridge polls
# /history with exponential backoff up to POLL_BACKOFF_MAX_S; on timeout
# it best-effort cancels the prompt at ComfyUI before raising.
# IMAGE_GEN_TIMEOUT_S=600

# Concurrency control. 1 (default) = single-flight via asyncio.Lock — the
# bridge serializes calls so concurrent generation can't pile up on the
# GB10 GPU while vLLM is also serving tokens. 0 = pass-through, let
# ComfyUI's internal queue handle ordering. Higher integers (2, 3, ...)
# allow that many concurrent renders through the bridge; the GPU still
# bottlenecks at one render at a time, so values >1 only help if your
# ComfyUI is on a different GPU/host than vLLM.
# IMAGE_GEN_MAX_CONCURRENCY=1

# Hard cap on the total bytes returned per `comfyui_image__generate` call
# (sum across all images in the batch). 50 MiB is generous for typical
# 1024x1024 PNGs (~1-3 MiB each); reduce to throttle agent context bloat
# if your workflow regularly produces big batches.
# IMAGE_GEN_MAX_OUTPUT_BYTES=52428800

# History-poll cadence. Start at 0.5s, exponential ×1.5 backoff, cap at 2s.
# Bumping these wastes operator-perceived latency; lowering them spams
# ComfyUI with HEAD/GET pings during long renders.
# IMAGE_GEN_POLL_INTERVAL_S=0.5
# IMAGE_GEN_POLL_BACKOFF_MAX_S=2.0

# Path A — chat-side inline image render via the [embed] shortcode.
# Set to /canvas to opt in. Pair with the volume mount in
# openclaw-image-comfyui/docker-compose.yml (uncomment the line marked
# `# Path A bind-mount`) so the bridge can write to the gateway's
# canvas dir at ${OPENCLAW_CONFIG_DIR}/canvas. Default (empty) keeps
# the legacy cross-origin URL emission. Run the SSH probe in
# docs/reference/image-comfyui-bridge.md → "Path A" first to confirm
# your deploy's canvas dir host path and that [embed] accepts .png
# MIME on your openclaw version.
# IMAGE_GEN_CANVAS_DIR=/canvas

# Sensible-defaults so the agent can call `comfyui_image__generate(prompt="…")`
# without remembering workflow + checkpoint names every time. When set, the
# bridge fills missing args from these env values; explicit caller args still
# win. Workflow names are the basename (without `.json`) of files under
# `openclaw-image-comfyui/server/workflows/`. Checkpoint names are the file
# names inside ComfyUI's `models/checkpoints/` directory.
#
# Pick a checkpoint that's actually installed on your ComfyUI host —
# without this, REPLACE_ME-templated workflows surface
# "checkpoint name required" errors on every conversational image-gen
# request. With this, your friend group can just say
# "@ImbulClaw generálj egy zsiráfot" and the bot fills the rest.
# IMAGE_GEN_DEFAULT_WORKFLOW=sdxl-base
# IMAGE_GEN_DEFAULT_CHECKPOINT=dreamshaper_8.safetensors

# Recommended defaults for the v0.11.0 FLUX-Krea-dev bundle. Uncomment
# ONLY after running the model + custom-node installs documented in
# `docs/reference/image-comfyui-bridge.md` → "Recommended model bundle".
# With this set, conversational requests like "@bot generate a sunset"
# route through the single-stage FLUX-Krea-dev path at 1280x720 default
# (16:9 widescreen, ~30s warm on GB10). Pass width=2048, height=2048
# to render at 2K square. The 4K-via-UltimateSDUpscale variants
# (flux-krea-4k-*) are intentionally not the default — verified on
# 2026-05-09 to produce visible tile seams and ghost faces on FLUX
# latents; use the 2K path + external ESRGAN if 4K is needed.
# IMAGE_GEN_DEFAULT_WORKFLOW=flux-krea-2k
# IMAGE_GEN_DEFAULT_CHECKPOINT line is intentionally NOT set — the
# flux-krea-2k workflow uses UNETLoader (not CheckpointLoaderSimple) so
# this var has no effect on it. Set only if you also use sdxl-base /
# flux-schnell as occasional fallbacks via explicit `workflow=` arg.

# =====================================================================
# LTX-Video 2.3 — video generation extension (v0.12.0+)
# =====================================================================
# Adds `comfyui_image__generate_video` MCP tool. Same bridge as image-gen,
# different workflows. Three independent levers (mirrors the image-gen
# activation triad above):
#   1. LTX_VIDEO_ENABLED=1 — flips the patcher cheatsheet block ON so the
#      discord-friend agent's AGENTS.md surfaces the video workflow picker.
#      WITHOUT this knob the `generate_video` tool still exists (the bridge
#      always advertises it) but the agent has no cheatsheet to discover
#      its arg names cleanly.
#   2. scripts/install-ltx-video.sh — downloads the ~71 GB LTX-2.3 model
#      bundle + Gemma 3 12B text encoder + git-clones the
#      Lightricks/ComfyUI-LTXVideo custom-node pack into your ComfyUI
#      basedir. Run this on the ComfyUI host. See
#      docs/reference/video-comfyui-bridge.md → "Recommended model bundle".
#   3. ComfyUI ≥ 0.17.0 — LTX-2.3 primitive nodes landed in 0.16.x but
#      the official Comfy-Org reference workflows use
#      `ComfyMathExpression` from 0.17.0 in their upscaler chain.
#      Earlier releases fail the workflow parse with `Unknown node:
#      LTXAVTextEncoderLoader` (pre-0.16.x) or "Some nodes may not work
#      correctly... Core nodes from version 0.17.0: ComfyMathExpression"
#      (0.16.x — partial, only single-stage works).
#
# Without ALL THREE, the tool surface exists but every call surfaces a
# "workflow not found" or "unknown node" error.
# LTX_VIDEO_ENABLED=

# Default frame count for `generate_video`. 193 frames @ 24 fps ≈ 8 seconds.
# Must follow the LTX `8k+1` rule (1, 9, 17, …, 97, 105, …, 193, 201, …).
# Higher → longer + more VRAM. Verified GB10 2026-05-14:
#   - 4s clip (97 frames) at 512×768: ~24-30 s warm, ~50-70 GB VRAM peak
#   - 8s clip (193 frames) at 512×768: ~56 s warm, **~116 GB VRAM peak**
#     (out of 121 GB unified; ~5 GB headroom — tight but stable)
# Pushing beyond 8 s at this resolution risks OOM. For longer clips,
# drop resolution (e.g. 384×512) to free activation memory, or accept
# the cap. Cold-cache first call adds ~100-130 s on top of all above.
# LTX_VIDEO_DEFAULT_LENGTH_FRAMES=193

# Default frames-per-second. 24 fps is the LTX-2.3 native and what the
# Gemma text encoder was conditioned on; deviations (e.g. 30) work but
# may produce slightly different motion quality. Stick to 24 for the
# canonical look.
# LTX_VIDEO_DEFAULT_FPS=24

# Default audio state — `on` mutes nothing, `off` removes the audio
# track from the mp4. LTX-2.3 generates audio in the same diffusion
# pass (no extra cost to keep it), so `on` is the recommended default.
# Per-call override: `audio_enabled=false` in the tool args.
# LTX_VIDEO_DEFAULT_AUDIO=on

# Hard ceiling on requested clip duration (seconds). The bridge rejects
# any (length / fps) > this value before submitting to ComfyUI, saving
# the operator a 5-minute wait on an obviously-too-long ask. 10 s
# default keeps clips below the ~50 MB Discord auto-embed cap with
# margin to spare; bump only if your Discord guild allows larger
# attachments AND you're patient.
# LTX_VIDEO_MAX_DURATION_S=10

# Quantization variant the operator picked at install time. Informational
# only — the bridge doesn't read this; the checkpoint name is baked into
# the workflow JSON (via the patcher cheatsheet or operator hand-edit).
# Useful for `./scripts/smoke-v0.11.sh`-style probes to log what's live.
#
# BF16 variants (Lightricks/LTX-2.3 repo, ~46 GB each):
#   distilled-1.1 (default — latest, fastest at matched quality)
#   distilled     (original distilled — kept for reproducibility)
#   dev           (full 22B dev model — highest quality, slowest)
#
# FP8 variants (Lightricks/LTX-2.3-fp8 repo, ~30 GB each — GB10-friendly):
#   fp8-distilled (original distilled in fp8; no fp8 -1.1 variant exists
#                  on HF as of 2026-05-13)
#   fp8-dev       (full dev model in fp8)
# LTX_VIDEO_QUANT=distilled-1.1
