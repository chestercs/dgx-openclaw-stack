# ============================================================================
# DGX OpenClaw Stack — .env template
# ============================================================================
# Copy this file to .env and fill in the placeholder values before running
# `docker compose up -d`. The included bootstrap.sh script can do this for you
# interactively — it's the recommended path for first-time setup.
#
#   cp .env.example .env
#   $EDITOR .env
#   # …or…
#   ./bootstrap.sh
#
# NEVER commit your real .env — it contains API keys and gateway tokens.
# The shipped .gitignore already excludes it.
# ============================================================================


# ----------------------------------------------------------------------------
# Secrets — generate strong random values (the bootstrap.sh script does this
# automatically with `openssl rand -base64 96`). Do NOT leave the placeholders.
# ----------------------------------------------------------------------------

# Shared API key for both vLLM services (LLM + embedding). The OpenClaw gateway
# uses this as its OPENAI_API_KEY when calling vllm-llm, and the patch-config
# script writes it into the memorySearch remote.apiKey for bge-m3.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
VLLM_API_KEY=CHANGE_ME_run_openssl_rand_base64_64

# OpenClaw gateway authentication token. Required to pair the Chrome extension
# or CLI with the gateway. Treat like a password.
# Recommended: 64+ chars of base64 — `openssl rand -base64 64`.
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_run_openssl_rand_base64_64

# SearxNG cookie / CSRF signing key. SearxNG refuses to start with the shipped
# upstream placeholder. The bootstrap script generates a 64-char random value
# automatically; set it manually with `openssl rand -base64 64` if editing by hand.
SEARXNG_SECRET=CHANGE_ME_run_openssl_rand_base64_64

# Your HuggingFace access token. Needed for the initial model download.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
# The Gemma 4 31B-IT-NVFP4 model is gated — you must accept the license at
# https://huggingface.co/nvidia/Gemma-4-31B-IT-NVFP4 with the same HF account.
HUGGING_FACE_HUB_TOKEN=hf_CHANGE_ME


# ----------------------------------------------------------------------------
# Host paths (required)
#
# Absolute paths on the host where persistent data lives. The compose file
# bind-mounts these into the containers.
# ----------------------------------------------------------------------------

# HuggingFace cache — the ~16 GB Gemma weights + ~1 GB bge-m3 weights land here.
# Put this on your fastest local disk. Not on NFS.
VLLM_HF_CACHE_DIR=/opt/dgx-openclaw/hf-cache

# OpenClaw config dir — holds openclaw.json, memory/, heartbeat journals, etc.
# Back up regularly; this is your agent's long-term memory.
OPENCLAW_CONFIG_DIR=/opt/dgx-openclaw/openclaw-config

# OpenClaw workspace dir — the working directory the agent operates on.
# This is what the agent reads/writes when you tell it to edit files. Typically
# a git repo you want to let the agent work inside.
OPENCLAW_WORKSPACE_DIR=/opt/dgx-openclaw/workspace


# ----------------------------------------------------------------------------
# vLLM — Gemma 4 31B NVFP4 tuning
# ----------------------------------------------------------------------------

# Fraction of unified GPU memory reserved for the LLM. Default 0.68 leaves ~9 GB
# for the embedding stack and ~15 GB of host headroom for OS + Docker + misc.
# - 0.68: safe default with embedding stack running (≈58 GB KV cache).
# - 0.85: if you're NOT running the embedding service (≈86 GB KV cache).
# Do NOT exceed 0.90 on 128 GB unified memory — you'll starve the OS.
LLM_GPU_MEM_UTIL=0.68

# Max model context (tokens). 262144 = 256K, the Gemma 4 architecture maximum.
# Lower values save KV cache reservation but disable long-context workflows.
LLM_MAX_MODEL_LEN=262144

# Max concurrent sequences (continuous batching width). 2 is the sweet spot on
# a 128 GB GB10 with 0.68 util — supports two 110K-context chats preempt-free.
# Going higher requires raising LLM_GPU_MEM_UTIL (and therefore disabling the
# embedding stack or accepting smaller effective context per user).
LLM_MAX_NUM_SEQS=2


# ----------------------------------------------------------------------------
# vLLM — bge-m3 embedding tuning
# ----------------------------------------------------------------------------

# bge-m3 is tiny (~1.1 GB BF16). 0.03 is plenty and keeps the KV budget for Gemma.
EMBED_GPU_MEM_UTIL=0.03

# bge-m3 native context is 8K. No reason to lower — the embedding model doesn't
# allocate KV the way an autoregressive LLM does.
EMBED_MAX_MODEL_LEN=8192

# Max concurrent embedding requests. 2 matches the LLM concurrency.
EMBED_MAX_NUM_SEQS=2


# ----------------------------------------------------------------------------
# OpenClaw gateway
# ----------------------------------------------------------------------------

# Host port for the gateway's main Web UI + WebSocket RPC. Put this behind a
# reverse proxy (Nginx Proxy Manager, Caddy, Traefik) for internet access.
OPENCLAW_GATEWAY_PORT=18789

# Host port for the gateway's secondary control endpoint.
OPENCLAW_GATEWAY_CONTROL_PORT=18790

# Gateway bind mode:
#   - lan:     listen on 0.0.0.0 (accessible from LAN and host). Default.
#   - local:   listen on 127.0.0.1 only (container-local; must use a reverse
#              proxy that shares the network namespace).
OPENCLAW_GATEWAY_BIND=lan

# If you access the gateway directly from your LAN (bypassing any CDN/reverse
# proxy), add your LAN CIDR here so X-Forwarded-For audit passes. Leave empty
# if all access goes through a reverse proxy.
# Example: OPENCLAW_LAN_CIDR=192.168.1.0/24
OPENCLAW_LAN_CIDR=

# If your reverse proxy terminates TLS and the gateway sees plaintext ws://
# connections from the proxy, set this to 1. Required for Nginx Proxy Manager
# in front of a private-IP gateway.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1


# ----------------------------------------------------------------------------
# OpenClaw heartbeat — proactive agent check-ins
# ----------------------------------------------------------------------------

# Active hours (inclusive). Outside this window the heartbeat does not wake up
# — saves idle vLLM prefills overnight. Start > End wraps around midnight.
OPENCLAW_HEARTBEAT_ACTIVE_START=09:00
OPENCLAW_HEARTBEAT_ACTIVE_END=02:00

# IANA timezone for both heartbeat.activeHours AND dreaming.frequency.
# Examples: America/Los_Angeles, Europe/Berlin, Asia/Tokyo, UTC.
OPENCLAW_HEARTBEAT_TZ=UTC


# ----------------------------------------------------------------------------
# OpenClaw dreaming (REM-style memory consolidation)
# ----------------------------------------------------------------------------

# Set to 1 to enable nightly memory consolidation (light/deep/rem phases).
# Requires an OpenClaw image >= 2026.4.15. Older gateway tags reject the
# memory-core plugin schema — leave at 0 if you're on an older version.
OPENCLAW_ENABLE_DREAMING=0


# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------

# Docker Compose project name. Influences the prefix on all container names:
#   ${COMPOSE_PROJECT_NAME}-vllm-llm, etc.
COMPOSE_PROJECT_NAME=dgx-openclaw

# vLLM log verbosity (ERROR / WARNING / INFO / DEBUG).
VLLM_LOGGING_LEVEL=INFO

# Default container timezone for the OpenClaw services.
TZ=UTC
